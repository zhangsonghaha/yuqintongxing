/* components/custom/comment-input/index.wxss */
.comment-input-container {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background-color: #fff;
  border-top: 1rpx solid #e0e0e0;
  gap: 16rpx;
}

.input-wrapper {
  flex: 1;
  position: relative;
  background-color: #f5f5f5;
  border-radius: 24rpx;
  padding: 12rpx 20rpx;
  transition: all 0.3s ease;
}

.input-wrapper.focused {
  background-color: #fff;
  border: 2rpx solid #07c160;
}

.comment-input {
  width: 100%;
  font-size: 28rpx;
  line-height: 40rpx;
  min-height: 40rpx;
}

.char-count {
  position: absolute;
  right: 20rpx;
  bottom: 12rpx;
  font-size: 20rpx;
  color: #999;
}

.send-btn {
  padding: 12rpx 24rpx;
  background-color: #e0e0e0;
  color: #999;
  border-radius: 24rpx;
  font-size: 28rpx;
  border: none;
  transition: all 0.3s ease;
}

.send-btn.active {
  background-color: #07c160;
  color: #fff;
}

.send-btn:active {
  opacity: 0.8;
}

.send-btn[disabled] {
  background-color: #e0e0e0;
  color: #999;
}
