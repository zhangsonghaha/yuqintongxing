/* components/custom/comment-input/index.wxss */
.comment-input-container {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background-color: #fff;
  border-top: 1rpx solid #F0F0F0;
  gap: 16rpx;
  min-height: 100rpx;
  box-sizing: border-box;
}

.input-wrapper {
  flex: 1;
  position: relative;
  background-color: #f5f5f5;
  border-radius: 24rpx;
  padding: 12rpx 20rpx;
  transition: all 0.3s ease;
}

.input-wrapper.focused {
  background-color: #fff;
  border: 2rpx solid #FF6B9D;
}

.comment-input {
  width: 100%;
  font-size: 28rpx;
  line-height: 40rpx;
  min-height: 40rpx;
}

.char-count {
  position: absolute;
  right: 20rpx;
  bottom: 12rpx;
  font-size: 20rpx;
  color: #999;
}

.send-btn {
  padding: 12rpx 24rpx;
  background-color: #F0F0F0;
  color: #BBBBBB;
  border-radius: 48rpx;
  font-size: 28rpx;
  border: none;
  white-space: nowrap;
  flex-shrink: 0;
}

.send-btn.active {
  background: linear-gradient(135deg, #FF6B9D 0%, #FF4081 100%);
  color: #FFFFFF;
}

.send-btn:active {
  opacity: 0.8;
}

.send-btn[disabled] {
  background-color: #F0F0F0;
  color: #BBBBBB;
}

/* 输入框操作区域 */
.input-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 8rpx;
}

.emoji-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: #fff;
  transition: all 0.2s ease;
}

.emoji-btn:active {
  background-color: #f0f0f0;
  transform: scale(0.95);
}

.emoji-icon {
  font-size: 32rpx;
}

/* 表情面板遮罩 */
.emoji-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 999;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.emoji-mask.show {
  opacity: 1;
  visibility: visible;
}

/* 表情面板 */
.emoji-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 60vh;
  background-color: #fff;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 1000;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.emoji-panel.show {
  transform: translateY(0);
}

.emoji-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.emoji-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.emoji-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
  padding: 0 16rpx;
}

.emoji-close:active {
  opacity: 0.6;
}

.emoji-list {
  max-height: 50vh;
  padding: 16rpx 32rpx 32rpx;
}

.emoji-category {
  margin-bottom: 32rpx;
}

.category-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.emoji-grid {
  display: grid;
  grid-template-columns: repeat(8, 1fr);
  gap: 16rpx;
}

.emoji-item {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  font-size: 48rpx;
  border-radius: 12rpx;
  background-color: #f8f8f8;
  transition: all 0.2s ease;
}

.emoji-item:active {
  background-color: #FFE5EF;
  transform: scale(1.1);
}
