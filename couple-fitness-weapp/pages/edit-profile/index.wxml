<!-- 编辑资料页面 -->
<view class="container">

  <!-- 头像区域 -->
  <view class="avatar-section" bindtap="chooseAvatar">
    <view class="avatar-wrapper">
      <image wx:if="{{ userInfo.avatar }}" class="avatar" src="{{ userInfo.avatar }}" mode="aspectFill" />
      <view wx:else class="avatar-placeholder">
        <text class="avatar-text">{{ avatarText }}</text>
      </view>
      <view class="avatar-edit-badge">✏️</view>
    </view>
    <text class="avatar-hint">点击更换头像</text>
  </view>

  <!-- 基本信息表单 -->
  <van-cell-group custom-class="form-group">

    <van-field
      label="昵称"
      value="{{ userInfo.nickname }}"
      placeholder="请输入昵称"
      maxlength="20"
      bind:change="onNicknameInput"
      clearable
    />

    <van-cell
      title="性别"
      value="{{ genderOptions[genderIndex] }}"
      is-link
      bindtap="showGenderPicker"
    />

    <van-cell
      title="生日"
      value="{{ userInfo.birthday || '请选择' }}"
      is-link
      bindtap="showBirthdayPicker"
    />

    <van-field
      label="个性签名"
      value="{{ userInfo.signature }}"
      placeholder="写点什么吧..."
      type="textarea"
      maxlength="100"
      autosize
      bind:change="onSignatureInput"
    />

  </van-cell-group>

  <!-- 保存按钮 -->
  <view class="btn-wrap">
    <view class="save-btn {{ saving ? 'save-btn-disabled' : '' }}" bindtap="saveProfile">
      <view wx:if="{{ saving }}" class="save-btn-loading">
        <view class="loading-dot"></view>
        <text>保存中...</text>
      </view>
      <text wx:else>保存</text>
    </view>
  </view>

</view>

<!-- 性别选择弹窗 -->
<van-popup show="{{ showGender }}" position="bottom" bind:close="onGenderClose" round>
  <van-picker
    title="选择性别"
    columns="{{ genderOptions }}"
    default-index="{{ genderIndex }}"
    show-toolbar
    bind:confirm="onGenderConfirm"
    bind:cancel="onGenderClose"
  />
</van-popup>

<!-- 生日选择弹窗 -->
<van-popup show="{{ showBirthday }}" position="bottom" bind:close="onBirthdayClose" round>
  <van-datetime-picker
    type="date"
    title="选择生日"
    value="{{ birthdayTimestamp }}"
    min-date="{{ minDate }}"
    max-date="{{ maxDate }}"
    show-toolbar
    bind:confirm="onBirthdayConfirm"
    bind:cancel="onBirthdayClose"
  />
</van-popup>

<van-toast id="van-toast" />
