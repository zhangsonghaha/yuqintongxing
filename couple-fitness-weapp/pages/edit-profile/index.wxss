/* 编辑资料页面样式 */
@import '../../styles/colors.wxss';

.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #FFF5FB 0%, #FFE5F0 50%, #FFF0F6 100%);
  padding: 24rpx 0 60rpx;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 32rpx;
}

.avatar-wrapper {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 16rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid var(--primary-color);
}

.avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid var(--primary-color);
}

.avatar-text {
  font-size: 64rpx;
  font-weight: 700;
  color: white;
}

.avatar-edit-badge {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 48rpx;
  height: 48rpx;
  background-color: var(--primary-color);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  border: 4rpx solid white;
  box-shadow: 0 2px 8px rgba(255, 107, 157, 0.4);
}

.avatar-hint {
  font-size: 24rpx;
  color: var(--text-light);
}

/* 表单组 */
.form-group {
  margin: 0 24rpx 24rpx !important;
  border-radius: 16rpx !important;
  overflow: hidden;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06) !important;
}

/* 保存按钮 */
.btn-wrap {
  padding: 0 24rpx;
  margin-top: 16rpx;
}

.save-btn {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%) !important;
  border: none !important;
  box-shadow: 0 6px 20px rgba(255, 107, 157, 0.35) !important;
  font-size: 32rpx !important;
  font-weight: 600 !important;
  letter-spacing: 2rpx !important;
}

/* 保存按钮 */
.btn-wrap {
  padding: 0 24rpx;
  margin-top: 16rpx;
}

.save-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #E84C7A 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  box-shadow: 0 6px 20px rgba(255, 107, 157, 0.35);
  box-sizing: border-box;
}

.save-btn-disabled {
  opacity: 0.6;
}

.save-btn-loading {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #ffffff;
  font-size: 32rpx;
}

.save-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}
