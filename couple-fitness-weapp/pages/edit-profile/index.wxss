/* 编辑资料页面样式 */
@import '../../styles/colors.wxss';

.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #FFF5FB 0%, #FFE5F0 50%, #FFF0F6 100%);
  padding: 16px;
}

/* 头像区域 */
.avatar-section {
  background-color: var(--bg-white);
  border-radius: 12px;
  padding: 24px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  border: 1px solid var(--border-light);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20px;
  align-self: flex-start;
}

.avatar-wrapper {
  position: relative;
  width: 100px;
  height: 100px;
  margin-bottom: 12px;
}

.avatar {
  width: 100px;
  height: 100px;
  border-radius: 50%;
  border: 3px solid var(--primary-color);
}

.avatar-placeholder {
  width: 100px;
  height: 100px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3px solid var(--primary-color);
}

.avatar-text {
  font-size: 40px;
  font-weight: 700;
  color: white;
  text-transform: uppercase;
}

.avatar-edit-icon {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 32px;
  height: 32px;
  background-color: var(--primary-color);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  border: 2px solid white;
  box-shadow: 0 2px 8px rgba(255, 107, 157, 0.3);
}

.avatar-hint {
  font-size: 24rpx;
  color: var(--text-light);
}

/* 表单区域 */
.form-section {
  background-color: var(--bg-white);
  border-radius: 12px;
  padding: 20px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  border: 1px solid var(--border-light);
}

.form-item {
  margin-bottom: 20px;
  padding-bottom: 20px;
  border-bottom: 1px solid var(--border-light);
}

.form-item:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12px;
}

.form-input {
  width: 100%;
  padding: 12px;
  background-color: var(--bg-light);
  border-radius: 8px;
  font-size: 28rpx;
  color: var(--text-primary);
  border: 1px solid var(--border-light);
}

.form-input::placeholder {
  color: var(--text-light);
}

.form-picker {
  width: 100%;
  padding: 12px;
  background-color: var(--bg-light);
  border-radius: 8px;
  border: 1px solid var(--border-light);
}

.picker-value {
  font-size: 28rpx;
  color: var(--text-primary);
}

.form-textarea {
  width: 100%;
  min-height: 100px;
  padding: 12px;
  background-color: var(--bg-light);
  border-radius: 8px;
  font-size: 28rpx;
  color: var(--text-primary);
  border: 1px solid var(--border-light);
  line-height: 1.6;
}

.form-textarea::placeholder {
  color: var(--text-light);
}

/* 操作区域 */
.action-section {
  margin-top: 24px;
}

.btn-primary {
  width: 100%;
  padding: 18px;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  color: var(--text-white);
  border: none;
  border-radius: 12px;
  text-align: center;
  font-weight: 700;
  font-size: 32rpx;
  transition: all 0.3s ease;
  box-shadow: 0 6px 20px rgba(255, 107, 157, 0.35);
  letter-spacing: 1px;
}

.btn-primary:active:not(:disabled) {
  transform: scale(0.98);
  box-shadow: 0 3px 12px rgba(255, 107, 157, 0.25);
}

.btn-primary:disabled {
  opacity: 0.6;
  box-shadow: none;
}
