@import '../../styles/colors.wxss';

page {
  background: #F7F8FA;
}

.container {
  min-height: 100vh;
  background: #F7F8FA;
  padding-bottom: 60rpx;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 48rpx;
  background: linear-gradient(145deg, #FF6B9D 0%, #E84C7A 100%);
  position: relative;
}

.avatar-section::after {
  content: '';
  position: absolute;
  bottom: -32rpx;
  left: 0;
  right: 0;
  height: 64rpx;
  background: #F7F8FA;
  border-radius: 50% 50% 0 0 / 100% 100% 0 0;
}

.avatar-ring {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 16rpx;
  border-radius: 50%;
  padding: 4rpx;
  background: rgba(255,255,255,0.3);
}

.avatar {
  width: 152rpx;
  height: 152rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
}

.avatar-placeholder {
  width: 152rpx;
  height: 152rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(255,255,255,0.6);
}

.avatar-text {
  font-size: 64rpx;
  font-weight: 700;
  color: #fff;
}

.avatar-edit-badge {
  position: absolute;
  right: calc(50% - 80rpx - 4rpx);
  bottom: 56rpx;
  width: 48rpx;
  height: 48rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.15);
  z-index: 1;
}

.avatar-hint {
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
  position: relative;
  z-index: 1;
}

/* 表单卡片 */
.form-card {
  margin: 48rpx 32rpx 32rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.06);
}

.form-item {
  display: flex;
  align-items: center;
  padding: 32rpx 36rpx;
  min-height: 96rpx;
}

.form-item-textarea {
  align-items: flex-start;
  padding-top: 28rpx;
}

.form-label {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  width: 120rpx;
  flex-shrink: 0;
}

.form-value-row {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
}

.form-value {
  font-size: 30rpx;
  color: #333;
}

.form-placeholder {
  color: #BBBBBB;
}

.form-arrow {
  font-size: 36rpx;
  color: #CCCCCC;
  line-height: 1;
}

.form-divider {
  height: 1rpx;
  background: #F5F5F5;
  margin: 0 36rpx;
}

/* 保存按钮 */
.btn-wrap {
  padding: 0 32rpx;
  margin-top: 8rpx;
}

.save-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #E84C7A 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 28rpx rgba(255, 107, 157, 0.4);
  box-sizing: border-box;
}

.save-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.save-btn-disabled {
  opacity: 0.6;
}

.save-btn-loading {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #fff;
  font-size: 30rpx;
}
