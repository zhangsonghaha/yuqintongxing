<view class="login-container">
  <view class="login-header">
    <view class="logo">💪</view>
    <text class="title">情侣健身打卡</text>
    <text class="subtitle">一起运动，一起成长</text>
  </view>

  <view class="login-content">
    <view class="login-card">
      <text class="card-title">微信授权登录</text>
      <text class="card-description">使用微信账号快速登录，享受健身打卡服务</text>

      <button 
        class="wechat-login-btn {{loading ? 'loading' : ''}}"
        bind:tap="onWechatLogin"
        disabled="{{loading}}"
      >
        {{loading ? '登录中...' : '微信授权登录'}}
      </button>

      <view class="login-tips">
        <text class="tip-icon">ℹ️</text>
        <text class="tip-text">首次登录将自动创建账户</text>
      </view>
      
      <!-- 测试登录入口 -->
      <view class="test-login-link" bindtap="goToTestLogin">
        <text class="test-link-text">开发测试登录 ></text>
      </view>
    </view>
  </view>

  <view class="login-footer">
    <text class="footer-text">登录即表示同意</text>
    <text class="link">用户协议</text>
    <text class="footer-text">和</text>
    <text class="link">隐私政策</text>
  </view>
</view>
