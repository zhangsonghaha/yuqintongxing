@import '../../styles/colors.wxss';

.login-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(135deg, #FF6B9D 0%, #FFB3D9 100%);
  padding: 0;
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 30rpx 40rpx;
  color: white;
}

.logo {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 30rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 28rpx;
  opacity: 0.9;
}

.login-content {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 30rpx;
}

.login-card {
  width: 100%;
  background: white;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
}

.card-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.card-description {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
  line-height: 1.5;
}

.wechat-login-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #FFB3D9 100%);
  color: white;
  border: none;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  transition: all 0.3s ease;
  line-height: 100rpx;
  text-align: center;
}

.wechat-login-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.wechat-login-btn.loading {
  opacity: 0.7;
}

.btn-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 15rpx;
}

.login-tips {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  padding: 20rpx;
  border-radius: 8rpx;
  margin-top: 20rpx;
}

.tip-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #666;
}

.login-footer {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
  color: rgba(255, 255, 255, 0.8);
  font-size: 22rpx;
  flex-wrap: wrap;
}

.footer-text {
  margin: 0 5rpx;
}

.link {
  color: white;
  text-decoration: underline;
  margin: 0 5rpx;
}


/* 测试登录链接 */
.test-login-link {
  margin-top: 24px;
  text-align: center;
  padding: 16px;
  border-top: 1px solid #f0f0f0;
}

.test-link-text {
  font-size: 26rpx;
  color: #999;
  text-decoration: underline;
}
