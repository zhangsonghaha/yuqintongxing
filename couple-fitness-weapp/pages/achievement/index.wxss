/* pages/achievement/index.wxss */
@import '../../styles/colors.wxss';

.achievement-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #FFF5FB 0%, #FFE5F0 50%, #FFF0F6 100%);
  padding: 16px;
}

/* 头部统计 */
.header-section {
  margin-bottom: 24px;
}

.stats-card {
  background-color: var(--bg-white);
  border-radius: 16px;
  padding: 28px 20px;
  display: flex;
  align-items: center;
  box-shadow: 0 4px 16px rgba(255, 107, 157, 0.12);
  border: 1px solid rgba(255, 107, 157, 0.1);
}

.stats-icon {
  font-size: 80rpx;
  margin-right: 30rpx;
}

.stats-content {
  flex: 1;
}

.stats-title {
  font-size: 24rpx;
  color: var(--text-light);
  margin-bottom: 8px;
  font-weight: 500;
}

.stats-value {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--primary-color);
  letter-spacing: 1px;
}

/* 徽章区域 */
.badges-section {
  background-color: var(--bg-white);
  border-radius: 12px;
  padding: 20px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  border: 1px solid var(--border-light);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 16px;
  padding-bottom: 12px;
  border-bottom: 2px solid var(--primary-light);
}

/* 徽章网格 */
.badges-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
}

.badge-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12px 8px;
  border-radius: 8px;
  background-color: var(--bg-light);
  border: 1px solid var(--border-light);
  transition: all 0.3s ease;
}

.badge-item.unlocked {
  background: linear-gradient(135deg, #FFF5FB 0%, #FFE5F0 100%);
  border: 2px solid var(--primary-color);
  box-shadow: 0 2px 8px rgba(255, 107, 157, 0.15);
}

.badge-item.locked {
  opacity: 0.7;
  background-color: var(--bg-lighter);
}

.badge-icon-wrapper {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 16rpx;
}

.badge-icon {
  font-size: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}

.badge-item.locked .badge-icon {
  filter: grayscale(100%) brightness(1.2);
}

/* 即将解锁的徽章 */
.badge-item.almost-unlocked {
  opacity: 1;
  background: linear-gradient(135deg, #FFF9E6 0%, #FFE5F0 100%) !important;
  border: 2px dashed var(--warning-color) !important;
  animation: almost-unlock-pulse 2s ease-in-out infinite;
}

.badge-item.almost-unlocked .badge-icon {
  filter: grayscale(50%) brightness(1.1);
}

@keyframes almost-unlock-pulse {
  0%, 100% {
    box-shadow: 0 0 0 0 rgba(255, 152, 0, 0.4);
  }
  50% {
    box-shadow: 0 0 0 8rpx rgba(255, 152, 0, 0);
  }
}

.lock-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.25);
  border-radius: 50%;
}

.lock-icon {
  font-size: 40rpx;
}

/* 进度环 */
.progress-ring {
  position: absolute;
  top: -4rpx;
  left: -4rpx;
  right: -4rpx;
  bottom: -4rpx;
  pointer-events: none;
}

.progress-ring-circle {
  width: 108rpx;
  height: 108rpx;
  fill: none;
  stroke: var(--primary-color);
  stroke-width: 4rpx;
  stroke-linecap: round;
  transform: rotate(-90deg);
  transform-origin: 50% 50%;
  stroke-dasharray: 0 251;
  transition: stroke-dasharray 0.5s ease;
}

.badge-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
  text-align: center;
}

.badge-date {
  font-size: 22rpx;
  color: var(--primary-color);
  text-align: center;
  font-weight: 500;
}

/* 进度条包装器 */
.badge-progress-wrapper {
  width: 100%;
  margin-top: 4rpx;
}

/* 进度条 */
.badge-progress-bar {
  width: 100%;
  height: 8rpx;
  background: var(--border-light);
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 6rpx;
}

.badge-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-radius: 4rpx;
  transition: width 0.5s ease;
}

/* 即将解锁的进度条 */
.badge-item.almost-unlocked .badge-progress-fill {
  background: linear-gradient(90deg, var(--warning-color) 0%, #FF6B6B 100%);
  animation: progress-glow 1.5s ease-in-out infinite;
}

@keyframes progress-glow {
  0%, 100% {
    box-shadow: 0 0 4rpx rgba(255, 165, 0, 0.6);
  }
  50% {
    box-shadow: 0 0 8rpx rgba(255, 165, 0, 1);
  }
}

/* 进度文字 */
.badge-progress-text {
  font-size: 20rpx;
  color: var(--text-light);
  text-align: center;
}

.badge-item.almost-unlocked .badge-progress-text {
  color: var(--warning-color);
  font-weight: 600;
}

.badge-status {
  font-size: 22rpx;
  color: var(--text-light);
  text-align: center;
}

/* 加载状态 */
.loading-wrapper {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 80rpx 0;
}

/* 空状态 */
.empty-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

/* 提示信息 */
.tips-section {
  background-color: var(--bg-white);
  border-radius: 12px;
  padding: 20px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  border: 1px solid var(--border-light);
}

/* 条件列表 */
.condition-list {
  margin-top: 16px;
  margin-bottom: 20px;
}

.condition-item {
  background-color: var(--bg-light);
  border-radius: 8px;
  padding: 16px;
  margin-bottom: 12px;
  border-left: 4px solid var(--primary-color);
  transition: all 0.3s ease;
}

.condition-item:last-child {
  margin-bottom: 0;
}

.condition-item:active {
  background-color: var(--primary-light);
  transform: scale(0.98);
}

.condition-header {
  display: flex;
  align-items: center;
  margin-bottom: 8px;
}

.condition-icon {
  font-size: 48rpx;
  margin-right: 12px;
}

.condition-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.condition-desc {
  font-size: 26rpx;
  color: var(--primary-color);
  font-weight: 600;
  margin-bottom: 8px;
  padding-left: 60rpx;
}

.condition-detail {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  padding-left: 60rpx;
}

/* 提示底部 */
.tips-footer {
  border-top: 1px dashed var(--border-light);
  padding-top: 16px;
  margin-top: 16px;
}

.tip-item {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.8;
  margin-bottom: 8px;
  font-weight: 500;
}

.tip-item:last-child {
  margin-bottom: 0;
}

/* 解锁动画弹窗 */
.unlock-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.8);
  z-index: 9999;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.unlock-modal.show {
  opacity: 1;
}

/* 彩纸容器 */
.confetti-container {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
  pointer-events: none;
}

/* 彩纸粒子 */
.confetti-particle {
  position: absolute;
  top: -20rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 2rpx;
  animation: confetti-fall linear forwards;
}

@keyframes confetti-fall {
  0% {
    transform: translateY(0) rotate(0deg);
    opacity: 1;
  }
  100% {
    transform: translateY(100vh) rotate(720deg);
    opacity: 0;
  }
}

/* 解锁内容 */
.unlock-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: white;
  border-radius: 32rpx;
  padding: 60rpx 40rpx 40rpx;
  width: 560rpx;
  animation: unlock-scale-in 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55);
}

@keyframes unlock-scale-in {
  0% {
    transform: scale(0.3);
    opacity: 0;
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

/* 徽章包装器 */
.unlock-badge-wrapper {
  position: relative;
  margin-bottom: 30rpx;
  animation: unlock-badge-bounce 1s ease-in-out infinite;
}

@keyframes unlock-badge-bounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
}

/* 徽章图标 */
.unlock-badge-icon {
  font-size: 160rpx;
  animation: unlock-badge-rotate 2s linear infinite;
}

@keyframes unlock-badge-rotate {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}

/* 闪光效果 */
.unlock-sparkle {
  position: absolute;
  top: -20rpx;
  right: -20rpx;
  font-size: 60rpx;
  animation: unlock-sparkle 1.5s ease-in-out infinite;
}

@keyframes unlock-sparkle {
  0%, 100% {
    transform: scale(1) rotate(0deg);
    opacity: 1;
  }
  50% {
    transform: scale(1.3) rotate(180deg);
    opacity: 0.6;
  }
}

/* 解锁标题 */
.unlock-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
  animation: unlock-text-fade-in 0.8s ease 0.3s both;
}

/* 徽章名称 */
.unlock-badge-name {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--primary-color);
  margin-bottom: 16rpx;
  animation: unlock-text-fade-in 0.8s ease 0.4s both;
  letter-spacing: 1px;
}

/* 描述文字 */
.unlock-description {
  font-size: 28rpx;
  color: var(--text-secondary);
  text-align: center;
  margin-bottom: 12rpx;
  animation: unlock-text-fade-in 0.8s ease 0.5s both;
}

/* 解锁日期 */
.unlock-date {
  font-size: 24rpx;
  color: var(--text-light);
  animation: unlock-text-fade-in 0.8s ease 0.6s both;
}

@keyframes unlock-text-fade-in {
  0% {
    opacity: 0;
    transform: translateY(20rpx);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 关闭提示 */
.unlock-close {
  position: absolute;
  bottom: 80rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  animation: unlock-close-blink 2s ease-in-out infinite;
}

.unlock-close-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

@keyframes unlock-close-blink {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.3;
  }
}

/* 操作按钮 */
.unlock-actions {
  display: flex;
  gap: 20rpx;
  width: 100%;
  margin-top: 40rpx;
  animation: unlock-text-fade-in 0.8s ease 0.7s both;
}

.unlock-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  transition: all 0.3s ease;
}

.unlock-btn-primary {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
  color: white;
  box-shadow: 0 8rpx 20rpx rgba(255, 107, 157, 0.3);
}

.unlock-btn-primary:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 157, 0.3);
}

.unlock-btn-secondary {
  background: white;
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
}

.unlock-btn-secondary:active {
  transform: scale(0.95);
  background: rgba(255, 107, 157, 0.05);
}

/* 新解锁徽章的脉冲效果 */
.badge-item.newly-unlocked {
  animation: badge-pulse 1s ease-in-out;
}

@keyframes badge-pulse {
  0% {
    transform: scale(1);
    box-shadow: 0 0 0 0 rgba(255, 107, 157, 0.7);
  }
  50% {
    transform: scale(1.05);
    box-shadow: 0 0 0 20rpx rgba(255, 107, 157, 0);
  }
  100% {
    transform: scale(1);
    box-shadow: 0 0 0 0 rgba(255, 107, 157, 0);
  }
}
