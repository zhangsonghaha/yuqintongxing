@import '../../styles/colors.wxss';

page {
  background: #F7F8FA;
}

.page {
  min-height: 100vh;
  background: #F7F8FA;
  padding-bottom: 40rpx;
}

/* 顶部操作栏 */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #F0F0F0;
  margin-bottom: 16rpx;
}

.unread-badge {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.unread-num {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary-color);
}

.unread-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.all-read-tip {
  font-size: 26rpx;
  color: var(--success-color);
  font-weight: 500;
}

.mark-all-btn {
  padding: 12rpx 28rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #E84C7A 100%);
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
}

.mark-all-btn:active {
  opacity: 0.8;
}

/* 列表 */
.list {
  background: #fff;
  border-radius: 24rpx;
  margin: 0 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.06);
}

.item {
  position: relative;
  display: flex;
  align-items: flex-start;
  padding: 32rpx 28rpx;
  border-bottom: 1rpx solid #F5F5F5;
  background: #fff;
}

.item:last-child {
  border-bottom: none;
}

.item:active {
  background: #FFF5FB;
}

.item-unread {
  background: #FFFBFD;
}

/* 未读圆点 */
.dot {
  position: absolute;
  left: 12rpx;
  top: 40rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--primary-color);
}

/* 图标 */
.icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.icon-like {
  background: linear-gradient(135deg, #FFE5EE 0%, #FFD0E4 100%);
}

.icon-comment {
  background: linear-gradient(135deg, #EEF3FF 0%, #DDE8FF 100%);
}

.icon-emoji {
  font-size: 36rpx;
}

/* 内容 */
.content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  min-width: 0;
}

.content-top {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 6rpx;
}

.username {
  font-size: 28rpx;
  font-weight: 700;
  color: #222;
}

.action {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.quote {
  background: #FFF5FB;
  border-left: 4rpx solid var(--primary-color);
  border-radius: 0 8rpx 8rpx 0;
  padding: 12rpx 16rpx;
}

.quote-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.time {
  font-size: 22rpx;
  color: #BBBBBB;
}

/* 箭头 */
.arrow {
  font-size: 36rpx;
  color: #CCCCCC;
  margin-left: 12rpx;
  align-self: center;
  line-height: 1;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 40rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 32rpx;
  opacity: 0.4;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #999;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #BBBBBB;
}

/* 加载 */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
}
