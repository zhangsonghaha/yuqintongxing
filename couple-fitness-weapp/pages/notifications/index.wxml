<!-- 通知中心页面 -->
<view class="container">
  <!-- 顶部操作栏 -->
  <view class="header-actions">
    <text class="action-text" wx:if="{{ unreadCount > 0 }}" bindtap="markAllAsRead">全部标为已读</text>
  </view>

  <!-- 通知列表 -->
  <view class="notification-list" wx:if="{{ notifications.length > 0 }}">
    <view 
      class="notification-item {{ item.isRead ? 'read' : 'unread' }}" 
      wx:for="{{ notifications }}" 
      wx:key="notificationId"
      bindtap="onNotificationTap"
      data-item="{{ item }}"
    >
      <!-- 未读标记 -->
      <view class="unread-dot" wx:if="{{ !item.isRead }}"></view>
      
      <!-- 通知图标 -->
      <view class="notification-icon {{ item.type }}">
        <text wx:if="{{ item.type === 'like' }}">❤️</text>
        <text wx:if="{{ item.type === 'comment' }}">💬</text>
      </view>

      <!-- 通知内容 -->
      <view class="notification-content">
        <view class="notification-header">
          <text class="from-user">{{ item.fromUserNickname || '用户' }}</text>
          <text class="notification-action">
            {{ item.type === 'like' ? '点赞了你的打卡' : '评论了你的打卡' }}
          </text>
        </view>
        
        <view class="notification-detail" wx:if="{{ item.type === 'comment' && item.content }}">
          <text class="comment-content">{{ item.content }}</text>
        </view>
        
        <view class="notification-time">
          <text>{{ item.createdAt }}</text>
        </view>
      </view>

      <!-- 右箭头 -->
      <view class="notification-arrow">
        <text>></text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <van-empty 
    wx:if="{{ notifications.length === 0 && !loading }}"
    description="暂无通知"
    image="https://img.yzcdn.cn/vant/custom-empty-image.png"
  />

  <!-- 加载状态 -->
  <van-loading wx:if="{{ loading }}" type="spinner" color="#FF6B9D" vertical>
    加载中...
  </van-loading>
</view>
