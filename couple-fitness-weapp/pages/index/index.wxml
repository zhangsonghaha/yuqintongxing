<!-- 首页 -->
<view class="container">

  <!-- 导航栏 -->
  <view class="nav-bar">
    <text class="nav-title">首页</text>
    <view class="nav-actions">
      <view class="nav-btn-notify" bindtap="goToNotifications">
        <text class="notify-icon">🔔</text>
        <view wx:if="{{ unreadCount > 0 }}" class="notify-dot"/>
      </view>
      <view class="nav-btn-checkin" bindtap="handleCheckIn">
        <text class="checkin-plus">+</text>
        <text class="checkin-label">打卡</text>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{ loading }}" class="loading-container">
    <van-loading type="spinner" size="24px" color="#FF6B9D">加载中...</van-loading>
  </view>

  <!-- 主内容 -->
  <scroll-view wx:else scroll-y class="scroll-content">

    <!-- 情侣卡片 -->
    <view class="couple-card" bindtap="goToPartnerProfile">
      <view class="couple-card-left">
        <text class="couple-tag">💑 我们在一起</text>
        <text class="couple-days">第 {{ daysCount }} 天</text>
        <text class="couple-slogan">{{ todayStatus.userCheckedIn && todayStatus.partnerCheckedIn ? '今天双双打卡啦 🎉' : '继续加油，宝贝！' }}</text>
      </view>
      <view class="couple-avatars">
        <view class="avatar-item avatar-me">
          <image wx:if="{{ userInfo.avatar }}" class="avatar-img" src="{{ userInfo.avatar }}" mode="aspectFill"/>
          <view wx:else class="avatar-placeholder-sm">
            <text>{{ avatarText }}</text>
          </view>
        </view>
        <view class="avatar-item avatar-partner">
          <image wx:if="{{ partnerInfo.partnerAvatar }}" class="avatar-img" src="{{ partnerInfo.partnerAvatar }}" mode="aspectFill"/>
          <view wx:else class="avatar-placeholder-sm partner-color">
            <text>{{ partnerInfo ? partnerInfo.partnerNickname.substring(0,1) : 'TA' }}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 未配对提示 -->
    <view wx:if="{{ !partnerInfo }}" class="no-partner-card" bindtap="goToPartnership">
      <text class="no-partner-emoji">💌</text>
      <text class="no-partner-text">还没有配对伴侣，快去邀请TA吧</text>
      <text class="no-partner-arrow">›</text>
    </view>

    <!-- 三个统计卡片 -->
    <view class="stats-row">
      <view class="stat-card">
        <text class="stat-emoji">🔥</text>
        <text class="stat-val">{{ consecutiveDays }}</text>
        <text class="stat-lbl">连续打卡</text>
      </view>
      <view class="stat-card">
        <text class="stat-emoji">⏱</text>
        <text class="stat-val">{{ userStats.weeklyDuration || 0 }}</text>
        <text class="stat-lbl">本周时长</text>
      </view>
      <view class="stat-card">
        <text class="stat-emoji">🏆</text>
        <text class="stat-val">Lv.{{ level }}</text>
        <text class="stat-lbl">当前等级</text>
      </view>
    </view>

    <!-- 今日状态 -->
    <view class="section-title">今日状态</view>
    <view class="today-row">
      <view class="today-card">
        <text class="today-who">我</text>
        <view class="today-status-row">
          <view class="status-dot {{ todayStatus.userCheckedIn ? 'dot-green' : 'dot-orange' }}"/>
          <text class="today-status-text {{ todayStatus.userCheckedIn ? 'text-green' : 'text-orange' }}">
            {{ todayStatus.userCheckedIn ? '已打卡 ✓' : '未打卡' }}
          </text>
        </view>
        <text class="today-detail">{{ todayStatus.userCheckedIn ? todayStatus.userCheckInTime : '快去打卡吧 💪' }}</text>
      </view>
      <view class="today-card" wx:if="{{ partnerInfo }}">
        <text class="today-who">TA</text>
        <view class="today-status-row">
          <view class="status-dot {{ todayStatus.partnerCheckedIn ? 'dot-green' : 'dot-orange' }}"/>
          <text class="today-status-text {{ todayStatus.partnerCheckedIn ? 'text-green' : 'text-orange' }}">
            {{ todayStatus.partnerCheckedIn ? '已打卡 ✓' : '未打卡' }}
          </text>
        </view>
        <text class="today-detail">{{ todayStatus.partnerCheckedIn ? todayStatus.partnerCheckInTime : '快去催催TA吧 💬' }}</text>
      </view>
    </view>

    <!-- 最近打卡 -->
    <view class="section-header" wx:if="{{ recentCheckIns.length > 0 }}">
      <text class="section-title-inline">最近打卡</text>
      <text class="section-more" bindtap="handleViewCalendar">查看更多 ›</text>
    </view>
    <view class="recent-list" wx:if="{{ recentCheckIns.length > 0 }}">
      <view
        class="recent-item"
        wx:for="{{ recentCheckIns }}"
        wx:key="recordId"
        bindtap="onCheckInCardTap"
        data-record-id="{{ item.recordId }}"
      >
        <view class="recent-icon-wrap {{ item.exerciseType === '跑步' ? 'icon-pink' : 'icon-blue' }}">
          <text class="recent-icon">{{ item.exerciseType === '跑步' ? '🏃' : item.exerciseType === '骑行' ? '🚴' : item.exerciseType === '瑜伽' ? '🧘' : '💪' }}</text>
        </view>
        <view class="recent-info">
          <text class="recent-name">{{ item.exerciseType }}</text>
          <text class="recent-meta">{{ item.duration }}分钟 · {{ item.checkInTime }}</text>
        </view>
        <view class="recent-badge {{ item.userId === userInfo.userId ? 'badge-me' : 'badge-partner' }}">
          <text>{{ item.userId === userInfo.userId ? '我' : 'TA' }}</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-section" wx:if="{{ !loading && recentCheckIns.length === 0 }}">
      <text class="empty-emoji">🏃</text>
      <text class="empty-text">还没有打卡记录</text>
      <text class="empty-hint">快去完成第一次打卡吧！</text>
    </view>

    <view class="bottom-space"/>
  </scroll-view>
</view>

<van-toast id="van-toast" />
<van-dialog id="van-dialog" />
