<!-- 首页 -->
<view class="container">
  <!-- 加载状态 -->
  <view wx:if="{{ loading }}" class="loading-container">
    <van-loading type="spinner" size="24px">加载中...</van-loading>
  </view>
  
  <!-- 错误提示 -->
  <van-empty
    wx:elif="{{ error }}"
    description="{{ error }}"
    image="error"
  >
    <van-button round type="primary" bind:click="loadData">重新加载</van-button>
  </van-empty>
  
  <!-- 主要内容 -->
  <view wx:else>
    <!-- 成就展示 -->
    <view class="achievement-section">
      <view class="achievement-card">
        <view class="achievement-item">
          <view class="achievement-label">连续打卡</view>
          <view class="achievement-value">{{ consecutiveDays }}</view>
          <view class="achievement-unit">天</view>
        </view>
        <view class="achievement-item">
          <view class="achievement-label">等级</view>
          <view class="achievement-value">Lv.{{ level }}</view>
          <view class="achievement-unit">💚</view>
        </view>
        <view class="achievement-item">
          <view class="achievement-label">经验值</view>
          <view class="achievement-value">{{ experience }}</view>
          <view class="achievement-unit">exp</view>
        </view>
      </view>
    </view>
    
    <!-- 本周统计 -->
    <view class="stats-section" wx:if="{{userStats}}">
      <view class="stats-title">本周统计</view>
      <view class="stats-grid">
        <view class="stat-item">
          <view class="stat-value">{{userStats.weeklyCheckIns || 0}}</view>
          <view class="stat-label">本周打卡</view>
        </view>
        <view class="stat-item">
          <view class="stat-value">{{userStats.weeklyDuration || 0}}</view>
          <view class="stat-label">运动时长</view>
        </view>
        <view class="stat-item">
          <view class="stat-value">{{userStats.weeklyCalories || 0}}</view>
          <view class="stat-label">消耗卡路里</view>
        </view>
      </view>
    </view>
    
    <!-- 个人状态 -->
    <view class="status-section">
      <view class="status-title">我的状态</view>
      <view class="status-item">
        <text class="status-label">今日打卡</text>
        <text class="status-value">{{ userStats.todayCheckInCount || 0 }}次</text>
      </view>
      <view class="status-item" wx:if="{{ todayStatus.userCheckInTime }}">
        <text class="status-label">最近打卡</text>
        <text class="status-value">{{ todayStatus.userCheckInTime }}</text>
      </view>
    </view>
    
    <!-- 对方状态 -->
    <view class="status-section partner-section">
      <view class="status-title">对方的状态</view>
      <view wx:if="{{ partnerInfo }}" class="partner-info-card">
        <!-- 伴侣头像和基本信息 - 点击跳转到伴侣主页 -->
        <view class="partner-header" bindtap="goToPartnerProfile">
          <image 
            wx:if="{{partnerInfo.partnerAvatar || partnerInfo.avatar}}" 
            class="partner-avatar" 
            src="{{partnerInfo.partnerAvatar || partnerInfo.avatar}}" 
            mode="aspectFill"
          />
          <view wx:else class="partner-avatar-placeholder">
            <text>{{partnerInfo.avatarText}}</text>
          </view>
          <view class="partner-info">
            <view class="partner-name">{{ partnerInfo.partnerNickname || partnerInfo.nickname || '对方' }}</view>
            <view class="partner-status">
              <text class="status-badge {{todayStatus.partnerCheckedIn ? 'checked' : 'unchecked'}}">
                今日{{ partnerStats.todayCheckInCount || 0 }}次
              </text>
              <text wx:if="{{ todayStatus.partnerCheckInTime }}" class="check-time">最近 {{ todayStatus.partnerCheckInTime }}</text>
            </view>
          </view>
          <van-icon name="arrow" class="arrow-icon" />
        </view>
        
        <!-- 本周对比数据 -->
        <view class="partner-stats" wx:if="{{partnerStats}}">
          <view class="stat-compare-item">
            <text class="stat-label">本周打卡</text>
            <text class="stat-value">{{partnerStats.weeklyCheckIns || 0}}次</text>
          </view>
          <view class="stat-compare-item">
            <text class="stat-label">运动时长</text>
            <text class="stat-value">{{partnerStats.weeklyDuration || 0}}分钟</text>
          </view>
          <view class="stat-compare-item">
            <text class="stat-label">消耗卡路里</text>
            <text class="stat-value">{{partnerStats.weeklyCalories || 0}}卡</text>
          </view>
        </view>
        
        <!-- 查看打卡记录按钮 -->
        <view class="partner-actions">
          <button class="btn-view-records" bindtap="goToPartnerCheckIns">
            查看TA的打卡记录
          </button>
        </view>
      </view>
      <view wx:else class="no-partner">
        <text class="no-partner-text">还没有配对伴侣</text>
        <button class="btn-go-pair" bindtap="goToPartnership">去配对</button>
      </view>
    </view>
    
    <!-- 打卡按钮 -->
    <view class="action-section">
      <button class="btn-primary" bindtap="handleCheckIn" disabled="{{ loading }}">
        打卡（3秒完成）
      </button>
    </view>
    
    <!-- 快捷操作 -->
    <view class="quick-action-section">
      <button class="btn-secondary" wx:if="{{ !todayStatus.partnerCheckedIn }}" bindtap="handleWakeUp">
        叫醒 TA
      </button>
      <button class="btn-secondary" bindtap="handleViewCalendar">
        查看日历
      </button>
    </view>
    
    <!-- 最近打卡记录 -->
    <view class="recent-section" wx:if="{{ recentCheckIns.length > 0 }}">
      <view class="section-header">
        <text class="section-title">最近打卡</text>
        <text class="section-more" bindtap="handleViewCalendar">查看更多 ></text>
      </view>
      <view class="recent-list">
        <check-in-card 
          wx:for="{{ recentCheckIns }}" 
          wx:key="recordId"
          record="{{ item }}"
          bind:cardtap="onCheckInCardTap"
          bind:likechange="onLikeChange"
          bind:comment="onComment"
          bind:interactionupdate="onInteractionUpdate"
        />
      </view>
    </view>
    
    <!-- 无打卡记录提示 -->
    <view class="empty-section" wx:if="{{ !loading && recentCheckIns.length === 0 }}">
      <text class="empty-text">还没有打卡记录</text>
      <text class="empty-hint">快去完成第一次打卡吧！</text>
    </view>
  </view>
</view>

<!-- Toast 和 Dialog -->
<van-toast id="van-toast" />
<van-dialog id="van-dialog" />
