@import '../../styles/colors.wxss';

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F8F8F8;
}

/* ===== 导航栏 ===== */
.nav-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 32rpx;
  background: #FFF5F8;
  height: 88rpx;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.nav-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.nav-btn-notify {
  position: relative;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.notify-icon {
  font-size: 40rpx;
}

.notify-dot {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 14rpx;
  height: 14rpx;
  background: #FF4081;
  border-radius: 7rpx;
  border: 2rpx solid #FFF5F8;
}

.nav-btn-checkin {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #FF4081 100%);
  border-radius: 32rpx;
  padding: 12rpx 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(255,107,157,0.4);
}

.checkin-plus {
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: 700;
  line-height: 1;
}

.checkin-label {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 600;
}

/* ===== 滚动区域 ===== */
.scroll-content {
  flex: 1;
  padding: 24rpx 24rpx 0;
}

.loading-container {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

/* ===== 情侣卡片 ===== */
.couple-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8FB3 50%, #FFB3D9 100%);
  border-radius: 32rpx;
  padding: 40rpx 48rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(255,107,157,0.35);
}

.couple-card-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.couple-tag {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
  font-weight: 500;
}

.couple-days {
  font-size: 56rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: -1rpx;
  line-height: 1.1;
}

.couple-slogan {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
}

.couple-avatars {
  display: flex;
  align-items: center;
}

.avatar-item {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  border: 4rpx solid #FFFFFF;
  overflow: hidden;
}

.avatar-item.avatar-partner {
  margin-left: -24rpx;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-placeholder-sm {
  width: 100%;
  height: 100%;
  background: #FFD6E8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #FF6B9D;
}

.avatar-placeholder-sm.partner-color {
  background: #FFB3D9;
}

/* ===== 未配对提示 ===== */
.no-partner-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.05);
}

.no-partner-emoji {
  font-size: 40rpx;
}

.no-partner-text {
  flex: 1;
  font-size: 26rpx;
  color: #666;
}

.no-partner-arrow {
  font-size: 36rpx;
  color: #C0C0C0;
}

/* ===== 统计三卡片 ===== */
.stats-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.stat-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 16rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.05);
}

.stat-emoji {
  font-size: 36rpx;
}

.stat-val {
  font-size: 40rpx;
  font-weight: 700;
  color: #FF6B9D;
  letter-spacing: -1rpx;
}

.stat-lbl {
  font-size: 22rpx;
  color: #9C9B99;
}

/* ===== 分区标题 ===== */
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A1A;
  margin-bottom: 16rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title-inline {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.section-more {
  font-size: 26rpx;
  color: #FF6B9D;
  font-weight: 500;
}

/* ===== 今日状态 ===== */
.today-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.today-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.05);
}

.today-who {
  font-size: 22rpx;
  color: #9C9B99;
  font-weight: 500;
}

.today-status-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 8rpx;
}

.dot-green { background: #4CAF50; }
.dot-orange { background: #FF9800; }

.today-status-text {
  font-size: 26rpx;
  font-weight: 600;
}

.text-green { color: #4CAF50; }
.text-orange { color: #FF9800; }

.today-detail {
  font-size: 22rpx;
  color: #9C9B99;
}

/* ===== 最近打卡列表 ===== */
.recent-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.recent-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.05);
}

.recent-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.icon-pink { background: #FFE8F0; }
.icon-blue { background: #E8F4FF; }
.icon-green { background: #E8F5E9; }

.recent-icon {
  font-size: 40rpx;
}

.recent-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.recent-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.recent-meta {
  font-size: 24rpx;
  color: #9C9B99;
}

.recent-badge {
  border-radius: 16rpx;
  padding: 6rpx 20rpx;
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.badge-me {
  background: #FFE8F0;
  color: #FF6B9D;
}

.badge-partner {
  background: #E8F4FF;
  color: #4A90D9;
}

/* ===== 空状态 ===== */
.empty-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  gap: 16rpx;
}

.empty-emoji {
  font-size: 80rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #666;
  font-weight: 600;
}

.empty-hint {
  font-size: 26rpx;
  color: #9C9B99;
}

.bottom-space {
  height: 40rpx;
}
