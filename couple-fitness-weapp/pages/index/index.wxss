/* 首页样式 - 卡片式设计 */

@import '../../styles/colors.wxss';

.container {
  padding: 16px;
  min-height: 100vh;
  background: linear-gradient(135deg, #FFF5FB 0%, #FFE5F0 50%, #FFF0F6 100%);
}

/* 加载状态 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  font-size: 28rpx;
  color: var(--text-light);
}

/* 错误提示 */
.error {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  color: var(--error-color);
  font-size: 28rpx;
}

/* 成就展示卡片 */
.achievement-section {
  margin-bottom: 24px;
}

.achievement-card {
  display: flex;
  justify-content: space-around;
  background-color: var(--bg-white);
  border-radius: 16px;
  padding: 28px 20px;
  box-shadow: 0 4px 16px rgba(255, 107, 157, 0.12);
  border: 1px solid rgba(255, 107, 157, 0.1);
}

.achievement-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.achievement-label {
  font-size: 24rpx;
  color: var(--text-light);
  margin-bottom: 8px;
  font-weight: 500;
}

.achievement-value {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--primary-color);
  margin-bottom: 4px;
  letter-spacing: 1px;
}

.achievement-unit {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 状态展示卡片 */
.status-section {
  margin-bottom: 16px;
  background-color: var(--bg-white);
  border-radius: 12px;
  padding: 20px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  border: 1px solid var(--border-light);
}

.status-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 16px;
  padding-bottom: 12px;
  border-bottom: 2px solid var(--primary-light);
}

.status-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid var(--border-light);
}

.status-item:last-child {
  border-bottom: none;
}

.status-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.status-value {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 600;
}

/* 未配对状态 */
.no-partner {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20px 0;
  text-align: center;
}

.no-partner-text {
  font-size: 28rpx;
  color: var(--text-light);
  margin-bottom: 16px;
}

.btn-go-pair {
  padding: 12px 32px;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  color: var(--text-white);
  border: none;
  border-radius: 8px;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.3s ease;
  box-shadow: 0 4px 12px rgba(255, 107, 157, 0.3);
}

.btn-go-pair:active {
  transform: scale(0.98);
  box-shadow: 0 2px 8px rgba(255, 107, 157, 0.2);
}

/* 操作区域 */
.action-section {
  margin: 28px 0;
}

.btn-primary {
  width: 100%;
  padding: 18px;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  color: var(--text-white);
  border: none;
  border-radius: 12px;
  text-align: center;
  font-weight: 700;
  font-size: 32rpx;
  transition: all 0.3s ease;
  box-shadow: 0 6px 20px rgba(255, 107, 157, 0.35);
  letter-spacing: 1px;
}

.btn-primary:active:not(:disabled) {
  transform: scale(0.98);
  box-shadow: 0 3px 12px rgba(255, 107, 157, 0.25);
}

.btn-primary:disabled {
  opacity: 0.6;
  box-shadow: none;
}

/* 快捷操作按钮 */
.quick-action-section {
  display: flex;
  gap: 12px;
  justify-content: center;
  margin-top: 16px;
}

.btn-secondary {
  flex: 1;
  padding: 14px;
  background-color: var(--bg-white);
  color: var(--primary-color);
  border: 2px solid var(--primary-color);
  border-radius: 10px;
  text-align: center;
  font-weight: 600;
  font-size: 26rpx;
  transition: all 0.3s ease;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
}

.btn-secondary:active {
  background-color: var(--primary-light);
  transform: scale(0.98);
}

/* 文本颜色 */
.text-success {
  color: var(--success-color);
}

.text-warning {
  color: var(--warning-color);
}

.text-danger {
  color: var(--error-color);
}
