<!--pages/checkin-detail/index.wxml-->
<van-toast id="van-toast" />

<view class="page-container">

  <!-- 加载中 -->
  <view class="loading-wrap" wx:if="{{ loading }}">
    <van-loading size="24px" color="#FF6B9D">加载中...</van-loading>
  </view>

  <!-- 详情内容 -->
  <view wx:if="{{ !loading && record }}" class="page-inner">

    <!-- 滚动内容区 -->
    <scroll-view scroll-y class="scroll-content" scroll-into-view="{{ scrollAnchor }}">

      <!-- 用户信息卡片 -->
      <view class="card user-card">
        <view class="user-left">
          <view class="avatar-circle">
            <image wx:if="{{ record.userAvatar }}" class="avatar-img" src="{{ record.userAvatar }}" mode="aspectFill"/>
            <text wx:else class="avatar-text">{{ record.isOwn ? '我' : 'TA' }}</text>
          </view>
          <view class="user-info">
            <text class="user-name">{{ record.userName || '微信用户' }}</text>
            <text class="user-time">{{ record.checkInDate }}  {{ record.createdAt }}</text>
          </view>
        </view>
        <view wx:if="{{ record.isOwn }}" class="delete-btn" bindtap="handleDelete">
          <text class="delete-icon">🗑</text>
        </view>
      </view>

      <!-- 运动信息卡片 -->
      <view class="card exercise-card">
        <view class="exercise-badge">
          <text class="exercise-badge-txt">{{ record.exerciseEmoji || '🏃' }} {{ record.exerciseType }}</text>
        </view>
        <view class="stats-row">
          <view class="stat-item">
            <text class="stat-icon">⏱</text>
            <text class="stat-val">{{ record.duration }}</text>
            <text class="stat-lbl">分钟</text>
          </view>
          <view class="stat-divider"/>
          <view class="stat-item">
            <text class="stat-icon">🔥</text>
            <text class="stat-val">{{ record.calories || 0 }}</text>
            <text class="stat-lbl">卡路里</text>
          </view>
        </view>
      </view>

      <!-- 打卡照片 -->
      <view class="card" wx:if="{{ record.photoUrl }}">
        <view class="section-header">
          <view class="section-bar"/>
          <text class="section-title">打卡照片</text>
        </view>
        <image class="photo-img" src="{{ record.photoUrl }}" mode="aspectFill" bindtap="previewPhoto"/>
      </view>

      <!-- 备注 -->
      <view class="card" wx:if="{{ record.notes }}">
        <view class="section-header">
          <view class="section-bar"/>
          <text class="section-title">备注</text>
        </view>
        <view class="notes-bg">
          <text class="notes-txt">{{ record.notes }}</text>
        </view>
      </view>

      <!-- 打卡位置 -->
      <view class="card" wx:if="{{ record.location }}">
        <view class="section-header">
          <view class="section-bar"/>
          <text class="section-title">打卡位置</text>
        </view>
        <view class="location-row" bindtap="viewLocation">
          <text class="location-pin">📍</text>
          <text class="location-addr">{{ record.location }}</text>
          <text class="location-arrow">›</text>
        </view>
      </view>

      <!-- 互动栏 -->
      <view class="card interaction-card">
        <interaction-bar
          recordId="{{ record.recordId }}"
          recordOwnerId="{{ record.userId }}"
          hasLiked="{{ record.hasLiked }}"
          likeCount="{{ record.likeCount }}"
          commentCount="{{ record.commentCount }}"
          bind:likechange="onLikeChange"
          bind:comment="onComment"
        />
      </view>

      <!-- 评论列表 -->
      <view class="card" wx:if="{{ comments.length > 0 }}">
        <view class="section-header">
          <view class="section-bar"/>
          <text class="section-title">评论 ({{ comments.length }})</text>
        </view>
        <view class="comment-list">
          <view class="comment-item" wx:for="{{ comments }}" wx:key="interactionId">
            <view class="comment-avatar-wrap">
              <image wx:if="{{ item.avatar }}" class="comment-avatar" src="{{ item.avatar }}" mode="aspectFill"/>
              <view wx:else class="comment-avatar-placeholder">
                <text class="comment-avatar-txt">{{ item.nickname ? item.nickname.substring(0,1) : 'U' }}</text>
              </view>
            </view>
            <view class="comment-body">
              <view class="comment-meta">
                <text class="comment-name">{{ item.nickname || '用户' }}</text>
                <text class="comment-time">{{ item.createdAt }}</text>
              </view>
              <text class="comment-content">
                <text wx:if="{{ item.replyToUserName }}" class="reply-to">回复 @{{ item.replyToUserName }}: </text>{{ item.content }}
              </text>
              <view class="comment-actions">
                <text class="action-reply"
                  data-interaction-id="{{ item.interactionId }}"
                  data-user-id="{{ item.userId }}"
                  data-user-name="{{ item.nickname }}"
                  bindtap="onReplyComment">回复</text>
                <text wx:if="{{ item.userId === currentUserId }}" class="action-delete"
                  data-interaction-id="{{ item.interactionId }}"
                  bindtap="onDeleteComment">删除</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- 无评论空状态 -->
      <view class="empty-comments" wx:if="{{ !loading && comments.length === 0 }}">
        <text class="empty-emoji">💬</text>
        <text class="empty-txt">还没有评论，快来抢沙发吧~</text>
      </view>

      <!-- 回复模式提示 -->
      <view class="reply-tip" wx:if="{{ replyMode }}">
        <text class="reply-tip-txt">回复 @{{ replyToUserName }}</text>
        <text class="reply-tip-close" bindtap="cancelReply">✕</text>
      </view>

      <view class="scroll-bottom" id="scroll-bottom-anchor"></view>
    </scroll-view>

    <!-- 底部评论输入栏 -->
    <view class="input-bar">
      <comment-input
        recordId="{{ record.recordId }}"
        placeholder="{{ replyPlaceholder }}"
        replyMode="{{ replyMode }}"
        replyToId="{{ replyToId }}"
        replyToUserId="{{ replyToUserId }}"
        replyToUserName="{{ replyToUserName }}"
        focus="{{ inputFocus }}"
        bind:commentsuccess="onCommentSuccess"
        bind:cancelreply="cancelReply"
        bind:interactionupdate="onInteractionUpdate"
        bind:inputblur="onInputBlur"
      />
    </view>

  </view>
</view>

<!-- 删除确认对话框 -->
<van-dialog
  id="van-dialog"
  show="{{ showDeleteDialog }}"
  title="确认删除"
  message="删除后将无法恢复，确定要删除这条打卡记录吗？"
  show-cancel-button
  confirm-button-text="删除"
  confirm-button-color="#FF6B9D"
  bind:confirm="confirmDelete"
  bind:cancel="cancelDelete"
/>
