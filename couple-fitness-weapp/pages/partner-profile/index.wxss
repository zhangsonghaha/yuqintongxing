/* 伴侣主页 - 重设计版 */

.container {
  min-height: 100vh;
  background: #F6F7F8;
}

.loading-center {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
}

/* ── Hero ── */
.hero {
  background: linear-gradient(180deg, #FFD6E7 0%, #FFF0F5 100%);
  padding: 88rpx 32rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  border: 6rpx solid #FFFFFF;
}

.avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #FFA8C5 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 6rpx solid #FFFFFF;
}

.avatar-text {
  font-size: 64rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.hero-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.hero-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #FFE5EF;
  border-radius: 24rpx;
  padding: 8rpx 24rpx;
}

.hero-tag-icon {
  font-size: 22rpx;
  color: #FF6B9D;
}

.hero-tag-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #FF6B9D;
}

/* ── 三项统计 ── */
.stats-bar {
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 32rpx 24rpx;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex: 1;
}

.stats-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #FF6B9D;
}

.stats-label {
  font-size: 22rpx;
  color: #9CA3AF;
}

.stats-divider {
  width: 1rpx;
  height: 64rpx;
  background: #F3F4F6;
}

/* ── 分隔 ── */
.section-gap {
  height: 16rpx;
  background: #F6F7F8;
}

/* ── 通用卡片 ── */
.card {
  background: #FFFFFF;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A1A;
}

/* ── 运动数据 ── */
.data-row {
  display: flex;
  justify-content: space-around;
}

.data-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.data-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.data-icon-pink { background: #FFF0F5; }
.data-icon-indigo { background: #F0F5FF; }
.data-icon-amber { background: #FFFBEB; }

.data-emoji {
  font-size: 40rpx;
}

.data-value {
  font-size: 36rpx;
  font-weight: 700;
}

.data-pink { color: #FF6B9D; }
.data-indigo { color: #6366F1; }
.data-amber { color: #D97706; }

.data-label {
  font-size: 22rpx;
  color: #9CA3AF;
}

/* ── 运动偏好 ── */
.pref-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.pref-label {
  width: 80rpx;
  font-size: 26rpx;
  color: #6B7280;
}

.pref-bar-bg {
  flex: 1;
  height: 16rpx;
  background: #F3F4F6;
  border-radius: 8rpx;
  overflow: hidden;
}

.pref-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF6B9D 0%, #FFA8C5 100%);
  border-radius: 8rpx;
}

.pref-count {
  width: 60rpx;
  text-align: right;
  font-size: 22rpx;
  color: #9CA3AF;
}

/* ── 标签页头部 ── */
.tab-header {
  background: #FFFFFF;
  display: flex;
  border-bottom: 1rpx solid #F3F4F6;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 0 0;
  gap: 20rpx;
}

.tab-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #9CA3AF;
  padding-bottom: 20rpx;
}

.tab-active .tab-text {
  font-weight: 600;
  color: #FF6B9D;
}

.tab-line {
  width: 60rpx;
  height: 4rpx;
  background: #FF6B9D;
  border-radius: 2rpx;
}

/* ── 标签页内容 ── */
.tab-content {
  background: #FFFFFF;
  padding: 32rpx;
}

.empty-state {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 300rpx;
  font-size: 28rpx;
  color: #9CA3AF;
}

/* 隐私提示 */
.privacy-notice {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  gap: 16rpx;
}

.privacy-icon { font-size: 96rpx; opacity: 0.5; }
.privacy-text { font-size: 30rpx; color: #6B7280; text-align: center; }
.privacy-hint { font-size: 24rpx; color: #9CA3AF; text-align: center; }

/* ── 成就网格 ── */
.ach-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.ach-item {
  width: calc(33.33% - 16rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 28rpx 0;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.ach-unlocked {
  background: #FFF0F5;
  border: 2rpx solid #FF6B9D;
}

.ach-locked {
  background: #F6F7F8;
  border: 2rpx solid transparent;
}

.ach-medal-wrap {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ach-medal-active {
  /* 已解锁：正常显示 */
}

.ach-medal-inactive {
  /* 未解锁：emoji 灰度 */
  filter: grayscale(100%);
  opacity: 0.5;
}

.ach-medal-img {
  width: 80rpx;
  height: 80rpx;
}

.ach-medal-emoji {
  font-size: 64rpx;
}

.ach-name {
  font-size: 22rpx;
  font-weight: 600;
  color: #9CA3AF;
  text-align: center;
}

.ach-name-active {
  color: #FF6B9D;
}

.ach-progress {
  font-size: 20rpx;
  color: #9CA3AF;
}

/* ── 打卡记录 ── */
.checkin-item {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.checkin-photo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.checkin-photo-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  background: #F6F7F8;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.checkin-photo-emoji { font-size: 48rpx; }

.checkin-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.checkin-type {
  font-size: 28rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.checkin-stats {
  display: flex;
  gap: 20rpx;
}

.checkin-stat {
  font-size: 24rpx;
  color: #6B7280;
}

.checkin-time {
  font-size: 22rpx;
  color: #9CA3AF;
}

.checkin-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  margin-left: 16rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.action-count {
  font-size: 22rpx;
  color: #9CA3AF;
}

/* ── 查看更多 ── */
.view-more {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8rpx;
  padding: 32rpx 0 8rpx;
}

.view-more-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #FF6B9D;
}
