<!-- profile 页面 -->
<view class="container">

  <!-- Hero 区域：渐变背景 + 头像 + 昵称 + 统计 -->
  <view class="profile-hero">
    <view class="avatar-wrapper" bindtap="editProfile">
      <view class="avatar-ring">
        <image wx:if="{{ userInfo.avatar }}" class="avatar" src="{{ userInfo.avatar }}" mode="aspectFill"/>
        <view wx:else class="avatar-placeholder">
          <text class="avatar-icon">👤</text>
        </view>
      </view>
      <view class="avatar-edit-badge">
        <text class="edit-icon">✏️</text>
      </view>
    </view>

    <text class="nickname">{{ userInfo.nickname || userInfo.nickName || '微信用户' }}</text>
    <text class="subtitle" wx:if="{{ partnerInfo }}">已配对 · 在一起第{{ daysCount }}天 💕</text>
    <text class="subtitle" wx:else>还未配对，快去找到你的另一半吧</text>

    <!-- 统计数字 -->
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-num">{{ totalCheckIns || 0 }}</text>
        <text class="stat-label">打卡天数</text>
      </view>
      <view class="stat-divider"/>
      <view class="stat-item">
        <text class="stat-num">{{ monthCheckIns || 0 }}</text>
        <text class="stat-label">本月打卡</text>
      </view>
      <view class="stat-divider"/>
      <view class="stat-item">
        <text class="stat-num">{{ achievementCount || 0 }}</text>
        <text class="stat-label">获得成就</text>
      </view>
    </view>
  </view>

  <!-- 滚动内容区 -->
  <view class="scroll-area">

    <!-- 通知中心 -->
    <view class="menu-card single" bindtap="goToNotifications">
      <view class="menu-icon-bg pink">
        <text class="menu-emoji">🔔</text>
      </view>
      <text class="menu-text">通知中心</text>
      <view wx:if="{{ unreadCount > 0 }}" class="unread-badge">{{ unreadCount > 99 ? '99+' : unreadCount }}</view>
      <text class="menu-arrow">›</text>
    </view>

    <!-- 情侣功能 -->
    <text class="section-label">情侣功能</text>
    <view class="menu-card">
      <view class="menu-row" bindtap="goToPartnership">
        <view class="menu-icon-bg pink">
          <text class="menu-emoji">💑</text>
        </view>
        <text class="menu-text">情侣配对</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-divider"/>
      <view class="menu-row" bindtap="viewPartner">
        <view class="menu-icon-bg blue">
          <text class="menu-emoji">👫</text>
        </view>
        <text class="menu-text">我的伴侣</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-divider"/>
      <view class="menu-row" bindtap="goToGoal">
        <view class="menu-icon-bg orange">
          <text class="menu-emoji">🎯</text>
        </view>
        <text class="menu-text">目标设置</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-divider"/>
      <view class="menu-row" bindtap="goToAchievement">
        <view class="menu-icon-bg yellow">
          <text class="menu-emoji">🏆</text>
        </view>
        <text class="menu-text">我的成就</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <!-- 个人设置 -->
    <text class="section-label">个人设置</text>
    <view class="menu-card">
      <view class="menu-row" bindtap="editProfile">
        <view class="menu-icon-bg lightblue">
          <text class="menu-emoji">✏️</text>
        </view>
        <text class="menu-text">编辑资料</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-divider"/>
      <view class="menu-row" bindtap="goToReminderSetting">
        <view class="menu-icon-bg green">
          <text class="menu-emoji">⏰</text>
        </view>
        <text class="menu-text">通知设置</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-divider"/>
      <view class="menu-row" bindtap="goToPrivacySetting">
        <view class="menu-icon-bg peach">
          <text class="menu-emoji">🔒</text>
        </view>
        <text class="menu-text">隐私与安全</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-divider"/>
      <view class="menu-row" bindtap="logout">
        <view class="menu-icon-bg red">
          <text class="menu-emoji">🚪</text>
        </view>
        <text class="menu-text logout-text">退出登录</text>
        <text class="menu-arrow logout-arrow">›</text>
      </view>
    </view>

    <view class="bottom-space"/>
  </view>

</view>
