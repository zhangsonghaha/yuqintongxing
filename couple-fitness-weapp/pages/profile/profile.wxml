<!-- profile 页面 -->
<view class="container">
  <view class="profile-header">
    <view class="avatar-wrapper">
      <image wx:if="{{ userInfo.avatar }}" class="avatar" src="{{ userInfo.avatar }}" mode="aspectFill"></image>
      <view wx:else class="avatar-placeholder">
        <text class="avatar-text">{{ avatarText }}</text>
      </view>
    </view>
    <view class="user-info">
      <text class="nickname">{{ userInfo.nickname || '用户' }}</text>
      <text class="user-id">ID: {{ userInfo.userId || '未知' }}</text>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-title">消息通知</view>
    <view class="menu-item" bindtap="goToNotifications">
      <view class="menu-item-left">
        <text class="menu-icon">🔔</text>
        <text class="menu-text">通知中心</text>
        <view wx:if="{{ unreadCount > 0 }}" class="unread-badge">{{ unreadCount > 99 ? '99+' : unreadCount }}</view>
      </view>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-title">情侣功能</view>
    <view class="menu-item" bindtap="goToPartnership">
      <view class="menu-item-left">
        <text class="menu-icon">💑</text>
        <text class="menu-text">情侣配对</text>
      </view>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" wx:if="{{ partnerInfo }}" bindtap="viewPartner">
      <view class="menu-item-left">
        <text class="menu-icon">👥</text>
        <text class="menu-text">我的伴侣</text>
      </view>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="goToGoal">
      <view class="menu-item-left">
        <text class="menu-icon">🎯</text>
        <text class="menu-text">目标设置</text>
      </view>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="goToAchievement">
      <view class="menu-item-left">
        <text class="menu-icon">🏆</text>
        <text class="menu-text">我的成就</text>
      </view>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-title">个人设置</view>
    <view class="menu-item" bindtap="editProfile">
      <view class="menu-item-left">
        <text class="menu-icon">✏️</text>
        <text class="menu-text">编辑资料</text>
      </view>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="goToReminderSetting">
      <view class="menu-item-left">
        <text class="menu-icon">⏰</text>
        <text class="menu-text">通知设置</text>
      </view>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="goToPrivacySetting">
      <view class="menu-item-left">
        <text class="menu-icon">🔒</text>
        <text class="menu-text">隐私与安全</text>
      </view>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item" bindtap="logout">
      <view class="menu-item-left">
        <text class="menu-icon">🚪</text>
        <text class="menu-text">退出登录</text>
      </view>
      <text class="menu-arrow">></text>
    </view>
  </view>
</view>