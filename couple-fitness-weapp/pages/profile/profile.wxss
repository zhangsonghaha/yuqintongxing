/* profile 页面样式 */

@import '../../styles/colors.wxss';

.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #FFFFFF 0%, #FFF5FB 100%);
}

/* 个人信息头部 */
.profile-header {
  display: flex;
  align-items: center;
  padding: 24px 16px;
  background-color: var(--bg-white);
  margin-bottom: 12px;
  box-shadow: var(--shadow-sm);
}

.avatar-wrapper {
  width: 64px;
  height: 64px;
  margin-right: 16px;
}

.avatar {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  border: 3px solid var(--primary-color);
}

.avatar-placeholder {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3px solid var(--primary-color);
}

.avatar-text {
  font-size: 28px;
  font-weight: 700;
  color: white;
  text-transform: uppercase;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 18px;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 4px;
}

.user-id {
  font-size: 12px;
  color: var(--text-light);
}

/* 菜单区域 */
.menu-section {
  background-color: var(--bg-white);
  margin-bottom: 12px;
  border-radius: 8px;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.menu-title {
  padding: 12px 16px;
  font-size: 12px;
  color: var(--text-light);
  background-color: var(--bg-lighter);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px;
  border-bottom: 1px solid var(--border-light);
  background-color: var(--bg-white);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background-color: var(--bg-light);
}

.menu-item-left {
  display: flex;
  align-items: center;
  position: relative;
}

/* 未读徽章 */
.unread-badge {
  position: absolute;
  left: 28px;
  top: -4px;
  min-width: 16px;
  height: 16px;
  padding: 0 4px;
  background: linear-gradient(135deg, #FF6B9D 0%, #FF4081 100%);
  color: white;
  font-size: 10px;
  font-weight: bold;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2px 4px rgba(255, 107, 157, 0.3);
  z-index: 10;
}

.menu-icon {
  font-size: 20px;
  margin-right: 12px;
  color: var(--primary-color);
}

.menu-text {
  font-size: 14px;
  color: var(--text-primary);
}

.menu-arrow {
  font-size: 14px;
  color: var(--text-light);
}

/* 操作按钮 */
.action-btn {
  background-color: var(--primary-color);
  color: var(--text-white);
  border: none;
  border-radius: 8px;
  padding: 12px 24px;
  font-size: 14px;
  font-weight: 600;
  margin: 16px;
  transition: all 0.3s ease;
}

.action-btn:active {
  background-color: var(--primary-dark);
  transform: scale(0.98);
}