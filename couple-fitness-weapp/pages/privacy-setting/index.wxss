@import '../../styles/colors.wxss';

page {
  background: #F7F8FA;
}

.page {
  min-height: 100vh;
  background: #F7F8FA;
  padding-bottom: 60rpx;
}

.hero {
  background: linear-gradient(145deg, #FF6B9D 0%, #E84C7A 100%);
  padding: 60rpx 40rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  position: relative;
}

.hero::after {
  content: '';
  position: absolute;
  bottom: -32rpx;
  left: 0;
  right: 0;
  height: 64rpx;
  background: #F7F8FA;
  border-radius: 50% 50% 0 0 / 100% 100% 0 0;
}

.hero-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.hero-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #fff;
  margin-bottom: 10rpx;
}

.hero-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
}

.section-label {
  font-size: 24rpx;
  color: #999;
  font-weight: 500;
  padding: 48rpx 36rpx 16rpx;
  letter-spacing: 1rpx;
}

.card {
  margin: 0 24rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.06);
}

.cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  min-height: 96rpx;
}

.cell-link:active {
  background: #FAFAFA;
}

.cell-danger:active {
  background: #FFF5F5;
}

.cell-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.cell-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  flex-shrink: 0;
}

.cell-icon-blue   { background: #E3F2FD; }
.cell-icon-green  { background: #E8F5E9; }
.cell-icon-yellow { background: #FFFDE7; }
.cell-icon-purple { background: #EDE7F6; }
.cell-icon-red    { background: #FFEBEE; }

.cell-title {
  font-size: 30rpx;
  color: #222;
  font-weight: 500;
}

.cell-title-danger {
  color: #F44336;
}

.cell-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.cell-value {
  font-size: 28rpx;
  color: #FF6B9D;
  font-weight: 600;
}

.cell-arrow {
  font-size: 36rpx;
  color: #CCCCCC;
  line-height: 1;
}

.cell-divider {
  height: 1rpx;
  background: #F5F5F5;
  margin: 0 32rpx;
}

.section-tip {
  display: block;
  font-size: 22rpx;
  color: #BBBBBB;
  padding: 12rpx 36rpx 0;
  line-height: 1.6;
}

.danger-tips {
  margin: 24rpx 24rpx 0;
  background: #FFF5F5;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  border: 1rpx solid #FFCDD2;
}

.danger-tip-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.danger-tip-item:last-child {
  margin-bottom: 0;
}

.danger-dot {
  font-size: 24rpx;
  flex-shrink: 0;
}

.danger-text {
  font-size: 24rpx;
  color: #E57373;
  line-height: 1.5;
}
