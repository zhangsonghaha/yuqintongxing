<view class="page">
  <van-toast id="van-toast" />
  <van-dialog id="van-dialog" />

  <!-- 已配对状态 -->
  <view class="paired-wrap" wx:if="{{ hasPaired }}">
    <!-- 顶部装饰 -->
    <view class="paired-hero">
      <view class="hero-bg"></view>
      <view class="hero-content">
        <view class="heart-icon">💑</view>
        <text class="paired-title">已配对</text>
        <text class="paired-sub">你们已成为健身伴侣</text>
      </view>
    </view>

    <!-- 伴侣信息卡片 -->
    <view class="partner-card">
      <view class="partner-avatar-box">
        <image wx:if="{{ partnerInfo.partnerAvatar }}" src="{{ partnerInfo.partnerAvatar }}" class="partner-avatar" mode="aspectFill" />
        <view wx:else class="partner-avatar-placeholder">
          <text>{{ partnerInfo.partnerNickname ? partnerInfo.partnerNickname.substring(0, 1) : '伴' }}</text>
        </view>
        <view class="online-ring"></view>
      </view>
      <view class="partner-info">
        <text class="partner-name">{{ partnerInfo.partnerNickname || '我的伴侣' }}</text>
        <view class="partner-meta">
          <text class="meta-icon">📅</text>
          <text class="meta-text">配对于 {{ partnerInfo.pairedAt || '未知' }}</text>
        </view>
      </view>
    </view>

    <!-- 解除按钮 -->
    <view class="dissolve-btn" bindtap="dissolvePartnership">
      <text>解除配对</text>
    </view>
  </view>

  <!-- 未配对状态 -->
  <view class="unpaired-wrap" wx:if="{{ !hasPaired }}">
    <!-- 顶部插图区 -->
    <view class="unpaired-hero">
      <view class="hero-emoji">💝</view>
      <text class="hero-title">邀请你的伴侣</text>
      <text class="hero-sub">一起开启健身之旅</text>
    </view>

    <!-- 标签页 -->
    <view class="tabs">
      <view class="tab {{ activeTab === 'generate' ? 'tab-active' : '' }}" bindtap="switchTab" data-tab="generate">生成邀请码</view>
      <view class="tab {{ activeTab === 'join' ? 'tab-active' : '' }}" bindtap="switchTab" data-tab="join">输入邀请码</view>
      <view class="tab {{ activeTab === 'pending' ? 'tab-active' : '' }}" bindtap="switchTab" data-tab="pending">待接受</view>
      <view class="tab-indicator" style="left: {{ activeTab === 'generate' ? '0%' : activeTab === 'join' ? '33.33%' : '66.66%' }}"></view>
    </view>

    <!-- 生成邀请码 -->
    <view class="tab-panel" wx:if="{{ activeTab === 'generate' }}">
      <view class="code-card" wx:if="{{ inviteCode }}">
        <text class="code-label">你的邀请码</text>
        <view class="code-display">
          <text wx:for="{{ inviteCode }}" wx:key="index" class="code-char">{{ item }}</text>
        </view>
        <view class="code-actions">
          <view class="code-btn code-btn-copy" bindtap="copyInviteCode">📋 复制</view>
          <view class="code-btn code-btn-save" wx:if="{{ qrCodeUrl }}" bindtap="saveQRCode">💾 保存二维码</view>
        </view>
        <view class="code-tip">⏰ 邀请码24小时内有效</view>
      </view>

      <view class="gen-btn {{ loading ? 'gen-btn-loading' : '' }}" bindtap="generateInviteCode" wx:if="{{ !inviteCode }}">
        <van-loading wx:if="{{ loading }}" color="#fff" size="36rpx" />
        <text wx:else>✨ 生成邀请码</text>
      </view>

      <view class="qr-section" wx:if="{{ qrCodeUrl }}">
        <image src="{{ qrCodeUrl }}" class="qr-img" mode="aspectFit" />
      </view>
    </view>

    <!-- 输入邀请码 -->
    <view class="tab-panel" wx:if="{{ activeTab === 'join' }}">
      <view class="scan-card" bindtap="scanQRCode">
        <text class="scan-icon">📷</text>
        <text class="scan-text">扫描伴侣二维码</text>
      </view>

      <view class="divider">
        <view class="divider-line"></view>
        <text class="divider-text">或手动输入</text>
        <view class="divider-line"></view>
      </view>

      <view class="input-card">
        <van-field
          value="{{ inputInviteCode }}"
          placeholder="请输入6位邀请码"
          maxlength="6"
          bind:change="onInviteCodeInput"
          center
          custom-style="font-size: 32rpx; letter-spacing: 8rpx; text-align: center;"
        />
      </view>

      <view class="submit-btn {{ (loading || inputInviteCode.length !== 6) ? 'submit-btn-disabled' : '' }}" bindtap="sendPartnershipRequest">
        <van-loading wx:if="{{ loading }}" color="#fff" size="36rpx" />
        <text wx:else>发送配对请求</text>
      </view>
    </view>

    <!-- 待接受请求 -->
    <view class="tab-panel" wx:if="{{ activeTab === 'pending' }}">
      <view class="loading-wrap" wx:if="{{ loadingRequests }}">
        <van-loading type="spinner" color="#FF6B9D" size="48rpx" />
      </view>

      <view wx:if="{{ !loadingRequests }}">
        <view class="request-item" wx:for="{{ pendingRequests }}" wx:key="partnershipId">
          <view class="req-avatar-box">
            <image wx:if="{{ item.partnerAvatar }}" src="{{ item.partnerAvatar }}" class="req-avatar" mode="aspectFill" />
            <view wx:else class="req-avatar-placeholder">
              <text>{{ item.partnerNickname ? item.partnerNickname.substring(0, 1) : '用' }}</text>
            </view>
          </view>
          <view class="req-info">
            <text class="req-name">{{ item.partnerNickname }}</text>
            <text class="req-time">{{ item.createdAt || '刚刚' }} 请求配对</text>
          </view>
          <view class="req-actions">
            <view class="req-btn req-accept" bindtap="acceptRequest" data-id="{{ item.partnershipId }}">接受</view>
            <view class="req-btn req-reject" bindtap="rejectRequest" data-id="{{ item.partnershipId }}">拒绝</view>
          </view>
        </view>

        <view class="empty-state" wx:if="{{ pendingRequests.length === 0 }}">
          <text class="empty-icon">📭</text>
          <text class="empty-text">暂无配对请求</text>
          <text class="empty-hint">分享邀请码给你的伴侣吧</text>
        </view>
      </view>
    </view>
  </view>
</view>
