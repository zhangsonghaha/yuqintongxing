<view class="partnership-container">
  <!-- Vant 组件 -->
  <van-toast id="van-toast" />
  <van-dialog id="van-dialog" />

  <!-- 已配对状态 -->
  <view class="partner-status" wx:if="{{hasPaired}}">
    <view class="status-card">
      <view class="status-header">
        <view class="status-icon">💑</view>
        <view class="status-text">已配对</view>
      </view>
      <view class="partner-info">
        <view class="partner-avatar-wrapper">
          <image wx:if="{{partnerInfo.partnerAvatar}}" src="{{partnerInfo.partnerAvatar}}" class="partner-avatar"></image>
          <view wx:else class="partner-avatar-placeholder">
            <text class="avatar-text">{{partnerInfo.partnerNickname ? partnerInfo.partnerNickname.substring(0, 1) : '伴'}}</text>
          </view>
        </view>
        <view class="partner-details">
          <view class="partner-name">{{partnerInfo.partnerNickname || '伴侣'}}</view>
          <view class="partner-meta">配对时间: {{partnerInfo.pairedAt || '未知'}}</view>
        </view>
      </view>
      <van-button 
        type="default" 
        block 
        custom-class="btn-dissolve-vant"
        bindtap="dissolvePartnership"
      >
        解除配对
      </van-button>
    </view>
  </view>

  <!-- 未配对状态 - 标签页 -->
  <view class="tabs" wx:if="{{!hasPaired}}">
    <view class="tab-item {{activeTab === 'generate' ? 'active' : ''}}" bindtap="switchTab" data-tab="generate">
      生成邀请码
    </view>
    <view class="tab-item {{activeTab === 'join' ? 'active' : ''}}" bindtap="switchTab" data-tab="join">
      输入邀请码
    </view>
    <view class="tab-item {{activeTab === 'pending' ? 'active' : ''}}" bindtap="switchTab" data-tab="pending">
      待接受请求
    </view>
  </view>

  <!-- 生成邀请码标签页 -->
  <view class="tab-content" wx:if="{{activeTab === 'generate' && !hasPaired}}">
    <view class="section">
      <view class="section-title">邀请伴侣加入</view>
      <view class="section-desc">分享邀请码或二维码给你的伴侣</view>

      <!-- 加载状态 -->
      <view class="loading-box" wx:if="{{loading && !inviteCode}}">
        <van-loading size="48px" color="#FF6B9D">生成中...</van-loading>
      </view>

      <view class="invite-code-box" wx:if="{{inviteCode}}">
        <view class="code-label">邀请码</view>
        <view class="code-display">{{inviteCode}}</view>
        <van-button 
          type="default" 
          block 
          custom-class="btn-copy-vant"
          bindtap="copyInviteCode"
        >
          复制邀请码
        </van-button>
      </view>

      <view class="qr-code-box" wx:if="{{qrCodeUrl}}">
        <view class="code-label">二维码</view>
        <image src="{{qrCodeUrl}}" class="qr-code" mode="aspectFit"></image>
        <van-button 
          type="default" 
          block 
          custom-class="btn-save-vant"
          bindtap="saveQRCode"
        >
          保存二维码
        </van-button>
      </view>

      <van-button 
        type="primary" 
        block 
        wx:if="{{!inviteCode && !loading}}" 
        loading="{{loading}}"
        bindtap="generateInviteCode"
      >
        生成邀请码
      </van-button>

      <view class="tip-box" wx:if="{{inviteCode}}">
        <view class="tip-icon">💡</view>
        <view class="tip-text">邀请码有效期为24小时，请及时分享给伴侣</view>
      </view>
    </view>
  </view>

  <!-- 输入邀请码标签页 -->
  <view class="tab-content" wx:if="{{activeTab === 'join' && !hasPaired}}">
    <view class="section">
      <view class="section-title">加入伴侣</view>
      <view class="section-desc">扫描伴侣的二维码，或手动输入邀请码</view>

      <!-- 扫一扫按钮 -->
      <view class="scan-btn" bindtap="scanQRCode">
        <text class="scan-icon">📷</text>
        <text class="scan-text">扫描伴侣二维码</text>
      </view>

      <view class="divider-row">
        <view class="divider-line"></view>
        <text class="divider-text">或手动输入</text>
        <view class="divider-line"></view>
      </view>

      <view class="form-group">
        <van-field
          value="{{ inputInviteCode }}"
          label="邀请码"
          placeholder="请输入6位邀请码"
          maxlength="6"
          bind:change="onInviteCodeInput"
          border="{{ true }}"
          custom-style="background-color: #fff;"
        />
        <view class="input-hint">邀请码为6位字母或数字组合</view>
      </view>

      <van-button 
        type="primary" 
        block 
        loading="{{loading}}"
        disabled="{{loading || inputInviteCode.length !== 6}}"
        bindtap="sendPartnershipRequest"
      >
        发送配对请求
      </van-button>
    </view>
  </view>

  <!-- 待接受请求标签页 -->
  <view class="tab-content" wx:if="{{activeTab === 'pending' && !hasPaired}}">
    <view class="section">
      <view class="section-title">配对请求</view>
      <view class="section-desc">来自伴侣的配对请求</view>

      <!-- 加载状态 -->
      <view class="loading-box" wx:if="{{loadingRequests}}">
        <van-loading size="48px" color="#FF6B9D">加载中...</van-loading>
      </view>

      <view class="pending-list" wx:if="{{!loadingRequests}}">
        <view class="pending-item" wx:for="{{pendingRequests}}" wx:key="partnershipId">
          <view class="item-header">
            <view class="avatar-wrapper">
              <image wx:if="{{item.partnerAvatar}}" src="{{item.partnerAvatar}}" class="avatar"></image>
              <view wx:else class="avatar-placeholder">
                <text class="avatar-text-small">{{item.partnerNickname ? item.partnerNickname.substring(0, 1) : '用'}}</text>
              </view>
            </view>
            <view class="item-info">
              <view class="nickname">{{item.partnerNickname}}</view>
              <view class="time">{{item.createdAt || '刚刚'}}请求配对</view>
            </view>
          </view>
          <view class="item-actions">
            <van-button 
              type="primary" 
              size="small"
              custom-class="btn-accept-vant"
              bindtap="acceptRequest" 
              data-id="{{item.partnershipId}}"
              disabled="{{item.processing}}"
              loading="{{item.processing}}"
            >
              接受
            </van-button>
            <van-button 
              type="default" 
              size="small"
              custom-class="btn-reject-vant"
              bindtap="rejectRequest" 
              data-id="{{item.partnershipId}}"
              disabled="{{item.processing}}"
            >
              拒绝
            </van-button>
          </view>
        </view>

        <van-empty 
          wx:if="{{pendingRequests.length === 0}}"
          image="search"
          description="暂无配对请求"
        >
          <view class="empty-hint">分享你的邀请码给伴侣吧</view>
        </van-empty>
      </view>
    </view>
  </view>
</view>
