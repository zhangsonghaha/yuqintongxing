@import '../../styles/colors.wxss';

page {
  background: #F7F8FA;
}

.page {
  min-height: 100vh;
  background: #F7F8FA;
}

/* ===== 已配对状态 ===== */
.paired-wrap {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

.paired-hero {
  position: relative;
  height: 320rpx;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(145deg, #FF6B9D 0%, #FF4081 60%, #E84C7A 100%);
}

.hero-bg::after {
  content: '';
  position: absolute;
  bottom: -40rpx;
  left: 0;
  right: 0;
  height: 80rpx;
  background: #F7F8FA;
  border-radius: 50% 50% 0 0 / 100% 100% 0 0;
}

.hero-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding-bottom: 20rpx;
}

.heart-icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
  animation: heartbeat 2s ease-in-out infinite;
}

@keyframes heartbeat {
  0%, 100% { transform: scale(1); }
  30% { transform: scale(1.15); }
  60% { transform: scale(1); }
}

.paired-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 4rpx;
}

.paired-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 8rpx;
}

.partner-card {
  margin: 0 32rpx;
  background: #fff;
  border-radius: 28rpx;
  padding: 40rpx 36rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 40rpx rgba(255, 107, 157, 0.15);
  border: 2rpx solid rgba(255, 107, 157, 0.1);
}

.partner-avatar-box {
  position: relative;
  width: 112rpx;
  height: 112rpx;
  margin-right: 32rpx;
  flex-shrink: 0;
}

.partner-avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  border: 4rpx solid #FF6B9D;
}

.partner-avatar-placeholder {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B9D 0%, #E84C7A 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
}

.online-ring {
  position: absolute;
  inset: -6rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 107, 157, 0.3);
  animation: pulse-ring 2.5s ease-in-out infinite;
}

@keyframes pulse-ring {
  0%, 100% { transform: scale(1); opacity: 0.6; }
  50% { transform: scale(1.08); opacity: 0.2; }
}

.partner-info {
  flex: 1;
}

.partner-name {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 12rpx;
}

.partner-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-icon { font-size: 24rpx; }

.meta-text {
  font-size: 24rpx;
  color: #999;
}

.dissolve-btn {
  margin: 40rpx 32rpx 0;
  height: 88rpx;
  border-radius: 44rpx;
  border: 2rpx solid #FF6B9D;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #FF6B9D;
  background: #fff;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 157, 0.12);
}

.dissolve-btn:active {
  background: #FFF5FB;
  opacity: 0.85;
}

/* ===== 未配对状态 ===== */
.unpaired-wrap {
  display: flex;
  flex-direction: column;
}

.unpaired-hero {
  background: linear-gradient(145deg, #FF6B9D 0%, #FF4081 100%);
  padding: 60rpx 40rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hero-emoji {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #fff;
  margin-bottom: 10rpx;
}

.hero-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
}

/* 标签页 */
.tabs {
  position: relative;
  display: flex;
  background: #fff;
  margin: -32rpx 32rpx 0;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.1);
  overflow: hidden;
  z-index: 10;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 26rpx;
  color: #999;
  font-weight: 500;
  position: relative;
  z-index: 1;
  transition: color 0.25s;
}

.tab-active {
  color: #FF6B9D;
  font-weight: 700;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  width: 33.33%;
  height: 4rpx;
  background: linear-gradient(90deg, #FF6B9D, #E84C7A);
  border-radius: 4rpx 4rpx 0 0;
  transition: left 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

/* 面板 */
.tab-panel {
  padding: 40rpx 32rpx;
}

/* 邀请码卡片 */
.code-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 36rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}

.code-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 24rpx;
  letter-spacing: 2rpx;
}

.code-display {
  display: flex;
  gap: 12rpx;
  margin-bottom: 36rpx;
}

.code-char {
  width: 72rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #FFF0F6 0%, #FFE5EE 100%);
  border-radius: 16rpx;
  border: 2rpx solid rgba(255, 107, 157, 0.25);
  font-size: 40rpx;
  font-weight: 800;
  color: #FF6B9D;
  font-family: 'Courier New', monospace;
  line-height: 88rpx;
  text-align: center;
}

.code-actions {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
  width: 100%;
}

.code-btn {
  flex: 1;
  height: 72rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
}

.code-btn:active { opacity: 0.8; }

.code-btn-copy {
  background: linear-gradient(135deg, #FF6B9D 0%, #E84C7A 100%);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 157, 0.35);
}

.code-btn-save {
  background: #fff;
  color: #FF6B9D;
  border: 2rpx solid #FF6B9D;
}

.code-tip {
  font-size: 22rpx;
  color: #BBBBBB;
}

/* 生成按钮 */
.gen-btn {
  height: 96rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #E84C7A 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  box-shadow: 0 8rpx 28rpx rgba(255, 107, 157, 0.4);
  letter-spacing: 2rpx;
}

.gen-btn:active { opacity: 0.85; transform: scale(0.98); }
.gen-btn-loading { opacity: 0.7; }

.qr-section {
  display: flex;
  justify-content: center;
  margin-top: 32rpx;
}

.qr-img {
  width: 280rpx;
  height: 280rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
}

/* 扫码卡片 */
.scan-card {
  background: linear-gradient(135deg, #FF6B9D 0%, #E84C7A 100%);
  border-radius: 24rpx;
  padding: 48rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 36rpx;
  box-shadow: 0 8rpx 28rpx rgba(255, 107, 157, 0.35);
}

.scan-card:active { opacity: 0.85; }

.scan-icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.scan-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}

/* 分割线 */
.divider {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: #EEEEEE;
}

.divider-text {
  font-size: 24rpx;
  color: #BBBBBB;
  padding: 0 24rpx;
}

/* 输入卡片 */
.input-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  margin-bottom: 32rpx;
}

/* 提交按钮 */
.submit-btn {
  height: 96rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #E84C7A 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  box-shadow: 0 8rpx 28rpx rgba(255, 107, 157, 0.4);
}

.submit-btn:active { opacity: 0.85; }

.submit-btn-disabled {
  background: linear-gradient(135deg, #CCCCCC 0%, #AAAAAA 100%);
  box-shadow: none;
  opacity: 0.6;
}

/* 请求列表 */
.request-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.req-avatar-box {
  width: 88rpx;
  height: 88rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.req-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  border: 3rpx solid #FF6B9D;
}

.req-avatar-placeholder {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B9D 0%, #E84C7A 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.req-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.req-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #222;
}

.req-time {
  font-size: 22rpx;
  color: #BBBBBB;
}

.req-actions {
  display: flex;
  gap: 16rpx;
}

.req-btn {
  height: 60rpx;
  padding: 0 28rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
}

.req-btn:active { opacity: 0.8; }

.req-accept {
  background: linear-gradient(135deg, #FF6B9D 0%, #E84C7A 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 157, 0.3);
}

.req-reject {
  background: #fff;
  color: #999;
  border: 2rpx solid #EEEEEE;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #999;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #BBBBBB;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
}
