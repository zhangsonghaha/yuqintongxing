<van-toast id="van-toast" />

<view class="checkin-container">
  <!-- 打卡表单 (支持一天多次打卡) -->
  <view class="checkin-form">
    <!-- 运动类型选择 -->
    <van-cell-group title="运动类型" inset>
      <van-cell 
        title="{{checkInForm.exerciseType || '选择运动类型'}}" 
        is-link 
        bind:click="showExerciseTypePicker"
      />
    </van-cell-group>

    <!-- 运动时长输入 -->
    <van-cell-group title="运动时长" inset custom-class="duration-group">
      <van-field
        type="number"
        value="{{ checkInForm.duration }}"
        placeholder="输入分钟数"
        bind:change="onDurationInput"
        right-icon="clock-o"
        maxlength="4"
        input-align="left"
      >
        <view slot="button" class="duration-unit">分钟</view>
      </van-field>
    </van-cell-group>

    <!-- 卡路里显示 -->
    <van-cell-group title="预计消耗" inset>
      <van-cell>
        <view class="calories-display">
          <text class="calories-value">{{estimatedCalories}}</text>
          <text class="calories-unit">卡路里</text>
        </view>
      </van-cell>
    </van-cell-group>

    <!-- 位置信息 -->
    <van-cell-group title="打卡位置" inset>
      <van-cell 
        wx:if="{{isGettingLocation}}"
        title="正在获取位置..."
        icon="location-o"
      />
      <van-cell 
        wx:elif="{{checkInForm.location}}"
        title="{{checkInForm.location}}"
        icon="location"
        is-link
        bind:click="refreshLocation"
      />
      <van-cell 
        wx:else
        title="点击获取位置"
        icon="location-o"
        is-link
        bind:click="getLocation"
      />
    </van-cell-group>

    <!-- 图片上传 -->
    <van-cell-group title="打卡照片" inset>
      <van-cell>
        <view class="photo-upload">
          <view wx:if="{{!checkInForm.photoUrl}}" class="upload-buttons">
            <van-button 
              icon="photograph" 
              type="default" 
              size="small"
              custom-class="photo-btn"
              bind:click="takePhoto"
              disabled="{{isUploading}}"
            >
              拍照
            </van-button>
            <van-button 
              icon="photo" 
              type="default" 
              size="small"
              custom-class="photo-btn"
              bind:click="chooseFromAlbum"
              disabled="{{isUploading}}"
            >
              相册
            </van-button>
          </view>
          
          <view wx:if="{{checkInForm.photoUrl}}" class="photo-preview">
            <image src="{{checkInForm.photoUrl}}" mode="aspectFill" class="preview-image" />
            <van-icon 
              name="cross" 
              class="delete-icon" 
              bind:click="deletePhoto"
            />
          </view>
          
          <van-loading wx:if="{{isUploading}}" type="spinner" size="24px">上传中...</van-loading>
        </view>
      </van-cell>
    </van-cell-group>

    <!-- 备注输入 -->
    <van-cell-group title="备注（可选）" inset>
      <van-field
        type="textarea"
        value="{{ checkInForm.notes }}"
        placeholder="记录你的运动感受..."
        bind:change="onNotesInput"
        autosize
        maxlength="200"
        show-word-limit
      />
    </van-cell-group>

    <!-- 提交按钮 -->
    <view class="form-actions">
      <button 
        class="submit-btn" 
        bindtap="submitCheckIn"
        disabled="{{isSubmitting || !checkInForm.exerciseType || !checkInForm.duration}}"
        loading="{{isSubmitting}}"
      >
        {{isSubmitting ? '提交中...' : '确认打卡'}}
      </button>
      <button class="cancel-btn" bindtap="cancelCheckIn" disabled="{{isSubmitting}}">
        取消
      </button>
    </view>
  </view>
</view>

<!-- 运动类型选择器 -->
<van-action-sheet
  show="{{ showExerciseTypeSheet }}"
  actions="{{ exerciseTypeActions }}"
  bind:select="onExerciseTypeSelect"
  bind:close="onExerciseTypeClose"
  cancel-text="取消"
  description="选择运动类型"
/>
