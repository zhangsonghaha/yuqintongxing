<van-toast id="van-toast" />

<!-- 打卡页面 -->
<view class="page-container">

  <!-- 导航栏（padding-top 适配状态栏高度） -->
  <view class="nav-bar" style="padding-top: {{ statusBarHeight }}px; height: {{ statusBarHeight + navBarHeight }}px;">
    <!-- 左侧返回按钮 -->
    <view class="nav-back" bindtap="cancelCheckIn">
      <text class="nav-back-icon">‹</text>
    </view>
    <!-- 标题居中 -->
    <text class="nav-title">打卡</text>
    <!-- 右侧留出胶囊按钮宽度，不放内容，避免遮挡 -->
    <view class="nav-right-placeholder" style="width: {{ menuButtonWidth + menuButtonRight * 2 }}px;"></view>
  </view>

  <!-- 滚动内容区 -->
  <scroll-view scroll-y class="scroll-content">

    <!-- 运动类型 -->
    <view class="card">
      <text class="card-label">运动类型</text>
      <view class="exercise-grid">
        <view class="exercise-row">
          <view
            class="exercise-item {{ checkInForm.exerciseType === item.value ? 'exercise-item-active' : '' }}"
            wx:for="{{ exerciseTypeList }}"
            wx:key="value"
            wx:if="{{ index < 4 }}"
            bindtap="onExerciseItemTap"
            data-value="{{ item.value }}"
            style="background:{{ checkInForm.exerciseType === item.value ? item.activeBg : item.bg }}"
          >
            <text class="exercise-emoji">{{ item.emoji }}</text>
            <text class="exercise-name" style="color:{{ checkInForm.exerciseType === item.value ? item.activeColor : item.color }}">{{ item.label }}</text>
          </view>
        </view>
        <view class="exercise-row">
          <view
            class="exercise-item {{ checkInForm.exerciseType === item.value ? 'exercise-item-active' : '' }}"
            wx:for="{{ exerciseTypeList }}"
            wx:key="value"
            wx:if="{{ index >= 4 }}"
            bindtap="onExerciseItemTap"
            data-value="{{ item.value }}"
            style="background:{{ checkInForm.exerciseType === item.value ? item.activeBg : item.bg }}"
          >
            <text class="exercise-emoji">{{ item.emoji }}</text>
            <text class="exercise-name" style="color:{{ checkInForm.exerciseType === item.value ? item.activeColor : item.color }}">{{ item.label }}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 运动时长 -->
    <view class="card">
      <text class="card-label">运动时长</text>
      <view class="input-row">
        <input
          class="duration-input"
          type="number"
          value="{{ checkInForm.duration }}"
          placeholder="输入分钟数"
          placeholder-class="input-placeholder"
          bindinput="onDurationInput"
          maxlength="4"
        />
        <view class="duration-right">
          <text class="duration-clock">⏱</text>
          <text class="duration-unit">分钟</text>
        </view>
      </view>
    </view>

    <!-- 预计消耗 -->
    <view class="card card-calories">
      <text class="card-label card-label-pink">预计消耗</text>
      <view class="calories-row">
        <text class="calories-value">{{ estimatedCalories }}</text>
        <text class="calories-unit">卡路里</text>
      </view>
    </view>

    <!-- 打卡位置 -->
    <view class="card">
      <text class="card-label">打卡位置</text>
      <view class="location-row" bindtap="refreshLocation">
        <view class="location-left">
          <text class="location-pin">📍</text>
          <text class="location-text {{ isGettingLocation ? 'location-loading' : '' }}">
            {{ isGettingLocation ? '正在获取位置...' : (checkInForm.location || '点击获取位置') }}
          </text>
        </view>
        <text class="row-arrow">›</text>
      </view>
    </view>

    <!-- 打卡照片 -->
    <view class="card">
      <text class="card-label">打卡照片</text>
      <view wx:if="{{ !checkInForm.photoUrl }}" class="photo-btns">
        <view class="photo-btn" bindtap="takePhoto">
          <text class="photo-btn-icon">📷</text>
          <text class="photo-btn-txt">拍照</text>
        </view>
        <view class="photo-btn" bindtap="chooseFromAlbum">
          <text class="photo-btn-icon">🖼</text>
          <text class="photo-btn-txt">相册</text>
        </view>
      </view>
      <view wx:if="{{ checkInForm.photoUrl }}" class="photo-preview-wrap">
        <image src="{{ checkInForm.photoUrl }}" mode="aspectFill" class="preview-img"/>
        <view class="preview-delete" bindtap="deletePhoto">
          <text class="preview-delete-icon">✕</text>
        </view>
      </view>
      <view wx:if="{{ isUploading }}" class="uploading-tip">
        <van-loading size="20px" color="#FF6B9D"/>
        <text class="uploading-txt">上传中...</text>
      </view>
    </view>

    <!-- 备注 -->
    <view class="card">
      <text class="card-label">备注（可选）</text>
      <view class="notes-wrap">
        <textarea
          class="notes-input"
          value="{{ checkInForm.notes }}"
          placeholder="记录你的运动感受..."
          placeholder-class="input-placeholder"
          bindinput="onNotesInput"
          maxlength="200"
          auto-height
        />
        <text class="notes-counter">{{ checkInForm.notes.length || 0 }}/200</text>
      </view>
    </view>

    <view class="bottom-safe"/>
  </scroll-view>

  <!-- 底部按钮（固定在底部，不随滚动） -->
  <view class="form-actions">
    <button
      class="submit-btn {{ (isSubmitting || !checkInForm.exerciseType || !checkInForm.duration) ? 'submit-btn-disabled' : '' }}"
      bindtap="submitCheckIn"
      disabled="{{ isSubmitting || !checkInForm.exerciseType || !checkInForm.duration }}"
      loading="{{ isSubmitting }}"
    >{{ isSubmitting ? '提交中...' : '确认打卡' }}</button>
    <button class="cancel-btn" bindtap="cancelCheckIn" disabled="{{ isSubmitting }}">取消</button>
  </view>
</view>
