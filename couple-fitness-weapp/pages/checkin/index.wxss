@import '../../styles/colors.wxss';

/* ===== 页面容器 ===== */
.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F8F8F8;
}

/* ===== 导航栏（与首页/我的页一致：粉色渐变） ===== */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  /* 不固定总高度，由 padding-top(状态栏) + 内容高度自适应 */
  padding-left: 32rpx;
  padding-right: 32rpx;
  padding-bottom: 20rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8FB3 100%);
  flex-shrink: 0;
  min-height: 88rpx;
  box-sizing: border-box;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255,255,255,0.25);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back:active { opacity: 0.7; }

.nav-back-icon {
  font-size: 44rpx;
  font-weight: 300;
  color: #FFFFFF;
  line-height: 1;
  margin-top: -4rpx;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.nav-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.nav-icon-btn {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255,255,255,0.25);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon-btn:active { opacity: 0.7; }
.nav-icon-emoji { font-size: 30rpx; }

.nav-divider {
  width: 2rpx;
  height: 36rpx;
  background: rgba(255,255,255,0.4);
}

/* ===== 滚动区域 ===== */
.scroll-content {
  flex: 1;
  padding: 24rpx 24rpx 0;
  box-sizing: border-box;
  /* 底部留出按钮区域 + 安全区高度 */
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

/* ===== 通用卡片（圆角 24rpx，与首页统一） ===== */
.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.05);
}

.card-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #FF6B9D;
  margin-bottom: 16rpx;
  display: block;
}

/* ===== 运动类型网格 ===== */
.exercise-grid {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.exercise-row {
  display: flex;
  gap: 12rpx;
}

.exercise-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 18rpx 0;
  border-radius: 20rpx;
  gap: 6rpx;
}

.exercise-item:active { opacity: 0.75; }

.exercise-item-active {
  box-shadow: 0 4rpx 16rpx rgba(255,107,157,0.20);
}

.exercise-emoji { font-size: 40rpx; }

.exercise-name {
  font-size: 22rpx;
  font-weight: 600;
}

/* ===== 运动时长 ===== */
.input-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 80rpx;
}

.duration-input {
  flex: 1;
  font-size: 32rpx;
  color: #1A1A1A;
  height: 80rpx;
  line-height: 80rpx;
}

.input-placeholder {
  color: #C0C0C0;
  font-size: 30rpx;
}

.duration-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.duration-clock { font-size: 30rpx; }

.duration-unit {
  font-size: 26rpx;
  font-weight: 500;
  color: #9C9B99;
}

/* ===== 预计消耗（渐变背景突出） ===== */
.card-calories {
  background: linear-gradient(135deg, #FFE8F0 0%, #FFF5F8 100%);
  border: 1.5rpx solid #FFCCE0;
}

.calories-row {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 10rpx;
  padding: 4rpx 0;
}

.calories-value {
  font-size: 80rpx;
  font-weight: 700;
  color: #FF6B9D;
  letter-spacing: -2rpx;
  line-height: 1;
}

.calories-unit {
  font-size: 26rpx;
  font-weight: 500;
  color: #9C9B99;
}

/* ===== 打卡位置 ===== */
.location-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 80rpx;
}

.location-row:active { opacity: 0.7; }

.location-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  overflow: hidden;
}

.location-pin { font-size: 30rpx; flex-shrink: 0; }

.location-text {
  font-size: 28rpx;
  color: #1A1A1A;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.location-loading { color: #9C9B99; }

.row-arrow {
  font-size: 36rpx;
  color: #C0C0C0;
  font-weight: 300;
  flex-shrink: 0;
  margin-left: 8rpx;
}

/* ===== 打卡照片 ===== */
.photo-btns {
  display: flex;
  gap: 24rpx;
  justify-content: center;
  padding: 4rpx 0;
}

.photo-btn {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 18rpx 40rpx;
  background: #F5F5F5;
  border-radius: 48rpx;
}

.photo-btn:active { opacity: 0.7; }
.photo-btn-icon { font-size: 30rpx; }

.photo-btn-txt {
  font-size: 26rpx;
  font-weight: 500;
  color: #666666;
}

.photo-preview-wrap {
  position: relative;
  width: 100%;
  height: 360rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.preview-img { width: 100%; height: 100%; }

.preview-delete {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 52rpx;
  height: 52rpx;
  background: rgba(0,0,0,0.55);
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-delete-icon {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.uploading-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 16rpx 0;
}

.uploading-txt {
  font-size: 26rpx;
  color: #9C9B99;
}

/* ===== 备注 ===== */
.notes-wrap { position: relative; }

.notes-input {
  width: 100%;
  min-height: 140rpx;
  font-size: 28rpx;
  color: #1A1A1A;
  line-height: 1.6;
  background: #F8F8F8;
  border-radius: 16rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

.notes-counter {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #C0C0C0;
  margin-top: 8rpx;
}

/* ===== 底部按钮（fixed 固定在底部） ===== */
.form-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #F8F8F8;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
  z-index: 100;
}

.submit-btn {
  flex: 1;
  height: 96rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #FF4081 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  box-shadow: 0 8rpx 24rpx rgba(255,107,157,0.40);
  line-height: 96rpx;
}

.submit-btn::after { border: none; }
.submit-btn:active { opacity: 0.85; }

.submit-btn-disabled {
  opacity: 0.5;
  box-shadow: none;
}

.cancel-btn {
  /* 固定宽度，不用 flex，防止被挤压 */
  width: 180rpx;
  flex-shrink: 0;
  height: 96rpx;
  background: #FFFFFF;
  color: #FF6B9D;
  border: 2rpx solid #FF6B9D;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 96rpx;
  box-sizing: border-box;
}

.cancel-btn::after { border: none; }
.cancel-btn:active { background: #FFE8F0; }
