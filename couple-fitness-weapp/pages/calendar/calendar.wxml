<!-- 日历页 -->
<view class="container">

  <scroll-view scroll-y class="scroll-content">

    <!-- 月历卡片 -->
    <view class="cal-card">
      <!-- 月份切换 -->
      <view class="cal-header">
        <view class="cal-nav-btn" bindtap="onPrevMonth">
          <text class="cal-nav-icon">‹</text>
        </view>
        <text class="cal-month-label">{{ currentYear }}年{{ currentMonth }}月</text>
        <view class="cal-nav-btn" bindtap="onNextMonth">
          <text class="cal-nav-icon">›</text>
        </view>
      </view>

      <!-- 星期标题 -->
      <view class="week-row">
        <text
          class="week-cell {{ index === 0 || index === 6 ? 'week-weekend' : '' }}"
          wx:for="{{ weekDays }}"
          wx:key="index"
        >{{ item }}</text>
      </view>

      <!-- 日期格子 -->
      <view class="date-grid">
        <view
          class="date-cell
            {{ !item.isCurrentMonth ? 'other-month' : '' }}
            {{ item.isToday && item.date !== selectedDate ? 'cell-today' : '' }}
            {{ item.date === selectedDate ? 'cell-selected' : '' }}
            {{ item.checkInType === 'me' && item.date !== selectedDate && !item.isToday ? 'cell-me' : '' }}
            {{ item.checkInType === 'partner' && item.date !== selectedDate && !item.isToday ? 'cell-partner' : '' }}
            {{ item.checkInType === 'both' && item.date !== selectedDate && !item.isToday ? 'cell-both' : '' }}"
          wx:for="{{ calendarDates }}"
          wx:key="index"
          bindtap="onDateClick"
          data-date="{{ item.date }}"
        >
          <text class="date-num">{{ item.day }}</text>
          <view wx:if="{{ item.checkInType }}" class="checkin-dot dot-{{ item.checkInType }} {{ item.date === selectedDate ? 'dot-white' : '' }}"/>
        </view>
      </view>
    </view>

    <!-- 图例 -->
    <view class="legend-row">
      <view class="legend-item">
        <view class="legend-dot dot-pink"/>
        <text class="legend-txt">我打卡</text>
      </view>
      <view class="legend-item">
        <view class="legend-dot dot-blue"/>
        <text class="legend-txt">TA打卡</text>
      </view>
      <view class="legend-item">
        <view class="legend-dot dot-green"/>
        <text class="legend-txt">双方打卡</text>
      </view>
    </view>

    <!-- 运动类型筛选 -->
    <view class="filter-wrap">
      <scroll-view scroll-x class="filter-scroll">
        <view
          class="filter-tag {{ filterType === '' ? 'tag-active' : '' }}"
          bindtap="onFilterTypeChange"
          data-type=""
        >全部</view>
        <view
          class="filter-tag {{ filterType === item.value ? 'tag-active' : '' }}"
          wx:for="{{ exerciseTypes }}"
          wx:key="value"
          bindtap="onFilterTypeChange"
          data-type="{{ item.value }}"
        >{{ item.label }}</view>
      </scroll-view>
    </view>

    <!-- 记录列表标题 -->
    <view class="section-header">
      <text class="section-title">{{ selectedDate ? selectedDate + ' 记录' : '本月记录' }}</text>
      <text class="section-count">共 {{ totalRecords }} 条</text>
    </view>

    <!-- 加载中 -->
    <view class="loading-wrap" wx:if="{{ loading }}">
      <van-loading size="24px" color="#FF6B9D">加载中...</van-loading>
    </view>

    <!-- 记录列表 -->
    <view class="record-list" wx:if="{{ !loading }}">
      <view
        class="record-item"
        wx:for="{{ records }}"
        wx:key="recordId"
        bindtap="onRecordTap"
        data-record-id="{{ item.recordId }}"
      >
        <!-- 运动图标 -->
        <view class="rec-icon-wrap {{ item.isPartner ? 'icon-blue' : 'icon-pink' }}">
          <text class="rec-icon">{{ item.exerciseIcon }}</text>
        </view>
        <!-- 信息 -->
        <view class="rec-info">
          <text class="rec-name">{{ item.exerciseType }}</text>
          <text class="rec-meta">{{ item.duration }}分钟 · {{ item.checkInDate }}</text>
        </view>
        <!-- 我/TA 徽章 -->
        <view class="rec-badge {{ item.isPartner ? 'badge-partner' : 'badge-me' }}">
          <text>{{ item.isPartner ? 'TA' : '我' }}</text>
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-wrap" wx:if="{{ records.length === 0 }}">
        <text class="empty-emoji">📅</text>
        <text class="empty-text">暂无打卡记录</text>
        <text class="empty-hint">{{ selectedDate ? '这天还没有打卡哦' : '本月还没有打卡记录' }}</text>
      </view>

      <!-- 加载更多 -->
      <view class="load-more" wx:if="{{ hasMore && records.length > 0 }}" bindtap="onLoadMore">
        <text class="load-more-txt">{{ loadingMore ? '加载中...' : '加载更多' }}</text>
      </view>
      <view class="no-more" wx:if="{{ !hasMore && records.length > 0 }}">
        <text class="no-more-txt">没有更多了</text>
      </view>
    </view>

    <view class="bottom-space"/>
  </scroll-view>
</view>

<van-toast id="van-toast"/>
