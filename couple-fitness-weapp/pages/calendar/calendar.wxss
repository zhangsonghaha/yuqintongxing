@import '../../styles/colors.wxss';

/* ===== 页面容器 ===== */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F8F8F8;
}

/* ===== 滚动区域 ===== */
.scroll-content {
  flex: 1;
  height: 0;
  padding: 20rpx 24rpx 0;
  box-sizing: border-box;
}

/* ===== 月历卡片 ===== */
.cal-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
}

.cal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx 16rpx;
}

.cal-nav-btn {
  width: 56rpx;
  height: 56rpx;
  background: #F5F5F5;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cal-nav-btn:active {
  background: #FFE8F0;
}

.cal-nav-icon {
  font-size: 36rpx;
  color: #666;
  font-weight: 300;
  line-height: 1;
}

.cal-month-label {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A1A;
}

/* 星期行 */
.week-row {
  display: flex;
  padding: 0 12rpx 12rpx;
}

.week-cell {
  width: 14.28%;
  text-align: center;
  font-size: 22rpx;
  color: #9C9B99;
}

.week-weekend {
  color: #FF6B9D;
}

/* 日期格子 */
.date-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 12rpx 20rpx;
}

.date-cell {
  width: 14.28%;
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  border-radius: 50%;
}

.date-num {
  font-size: 24rpx;
  color: #1A1A1A;
  font-weight: 400;
  line-height: 1;
}

.other-month .date-num {
  color: #D0D0D0;
}

/* 今天 */
.cell-today {
  background: rgba(255,107,157,0.12);
}

.cell-today .date-num {
  color: #FF6B9D;
  font-weight: 700;
}

/* 选中 */
.cell-selected {
  background: #FF6B9D;
}

.cell-selected .date-num {
  color: #FFFFFF;
  font-weight: 700;
}

/* 我打卡 */
.cell-me {
  background: #FFE8F0;
}
.cell-me .date-num {
  color: #FF6B9D;
  font-weight: 600;
}

/* TA打卡 */
.cell-partner {
  background: #E8F4FF;
}
.cell-partner .date-num {
  color: #4A90D9;
  font-weight: 600;
}

/* 双方打卡 */
.cell-both {
  background: #E8F5E9;
}
.cell-both .date-num {
  color: #4CAF50;
  font-weight: 600;
}

/* 打卡小点 */
.checkin-dot {
  position: absolute;
  bottom: 4rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 4rpx;
}

.dot-me { background: #FF6B9D; }
.dot-partner { background: #4A90D9; }
.dot-both { background: #4CAF50; }
.dot-white { background: #FFFFFF; }

/* ===== 图例 ===== */
.legend-row {
  display: flex;
  gap: 28rpx;
  align-items: center;
  padding: 0 4rpx;
  margin-bottom: 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 9rpx;
  flex-shrink: 0;
}

.dot-pink { background: #FF6B9D; }
.dot-blue { background: #4A90D9; }
.dot-green { background: #4CAF50; }

.legend-txt {
  font-size: 22rpx;
  color: #666;
}

/* ===== 筛选标签 ===== */
.filter-wrap {
  margin-bottom: 20rpx;
}

.filter-scroll {
  white-space: nowrap;
  padding-right: 24rpx;
}

.filter-tag {
  display: inline-block;
  padding: 10rpx 24rpx;
  margin-right: 12rpx;
  background: #F5F5F5;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #666;
  border: 2rpx solid transparent;
}

.tag-active {
  background: #FFE8F0;
  color: #FF6B9D;
  border-color: #FF6B9D;
  font-weight: 600;
}

/* ===== 记录列表标题 ===== */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.section-count {
  font-size: 22rpx;
  color: #9C9B99;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 60rpx 0;
}

/* ===== 记录列表 ===== */
.record-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.record-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.record-item:active {
  opacity: 0.85;
}

.rec-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.icon-pink { background: #FFE8F0; }
.icon-blue { background: #E8F4FF; }

.rec-icon {
  font-size: 36rpx;
}

.rec-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.rec-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.rec-meta {
  font-size: 22rpx;
  color: #9C9B99;
}

.rec-badge {
  border-radius: 14rpx;
  padding: 6rpx 18rpx;
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.badge-me {
  background: #FFE8F0;
  color: #FF6B9D;
}

.badge-partner {
  background: #E8F4FF;
  color: #4A90D9;
}

/* ===== 空状态 ===== */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  gap: 16rpx;
}

.empty-emoji { font-size: 72rpx; }
.empty-text { font-size: 28rpx; color: #666; font-weight: 600; }
.empty-hint { font-size: 24rpx; color: #9C9B99; }

/* ===== 加载更多 ===== */
.load-more {
  text-align: center;
  padding: 32rpx;
}

.load-more-txt {
  font-size: 26rpx;
  color: #FF6B9D;
}

.no-more {
  text-align: center;
  padding: 32rpx;
}

.no-more-txt {
  font-size: 24rpx;
  color: #C0C0C0;
}

/* 底部安全区 */
.bottom-space {
  height: calc(40rpx + env(safe-area-inset-bottom));
}
