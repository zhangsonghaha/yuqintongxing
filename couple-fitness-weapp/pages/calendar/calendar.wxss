/* calendar 页面样式 */

@import '../../styles/colors.wxss';

.container {
  padding: 16px;
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5FB 0%, #FFFFFF 100%);
}

/* 日历头部 */
.calendar-header {
  background-color: var(--bg-white);
  padding: 20rpx 16rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
}

.calendar-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

/* 日期项 */
.date-item {
  background-color: var(--bg-white);
  padding: 16rpx;
  margin-bottom: 12rpx;
  border-radius: 8rpx;
  border-left: 4rpx solid var(--primary-color);
}

.date-item:active {
  background-color: var(--bg-light);
}

.date-item-date {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary-color);
  margin-bottom: 8rpx;
}

.date-item-content {
  font-size: 24rpx;
  color: var(--text-secondary);
}