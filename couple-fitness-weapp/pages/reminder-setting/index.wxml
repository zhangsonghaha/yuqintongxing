<view class="reminder-setting-page">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="header-title">通知设置</text>
    <text class="header-desc">管理你的提醒和通知偏好</text>
  </view>

  <!-- 运动提醒设置 -->
  <view class="setting-section">
    <view class="section-title">运动提醒</view>
    
    <van-cell-group>
      <van-cell title="运动提醒" title-class="cell-title">
        <van-switch 
          slot="right-icon"
          checked="{{ setting.exerciseReminderEnabled }}"
          bind:change="onExerciseReminderChange"
          active-color="#FF6B9D"
        />
      </van-cell>
      
      <van-cell 
        wx:if="{{ setting.exerciseReminderEnabled }}"
        title="提醒时间" 
        value="{{ currentTime }}"
        is-link
        bind:click="showTimePicker"
        title-class="cell-title"
      />
    </van-cell-group>
    
    <view class="section-tip">
      <text>开启后，系统会在设定时间提醒你运动打卡</text>
    </view>
  </view>

  <!-- 互动通知设置 -->
  <view class="setting-section">
    <view class="section-title">互动通知</view>
    
    <van-cell-group>
      <van-cell title="点赞通知" title-class="cell-title">
        <van-switch 
          slot="right-icon"
          checked="{{ setting.likeNotificationEnabled }}"
          bind:change="onLikeNotificationChange"
          active-color="#FF6B9D"
        />
      </van-cell>
      
      <van-cell title="评论通知" title-class="cell-title">
        <van-switch 
          slot="right-icon"
          checked="{{ setting.commentNotificationEnabled }}"
          bind:change="onCommentNotificationChange"
          active-color="#FF6B9D"
        />
      </van-cell>
      
      <van-cell title="目标完成通知" title-class="cell-title">
        <van-switch 
          slot="right-icon"
          checked="{{ setting.goalNotificationEnabled }}"
          bind:change="onGoalNotificationChange"
          active-color="#FF6B9D"
        />
      </van-cell>
    </van-cell-group>
    
    <view class="section-tip">
      <text>接收伴侣的点赞、评论和目标完成提醒</text>
    </view>
  </view>

  <!-- 订阅消息按钮 -->
  <view class="subscribe-section">
    <van-button 
      type="primary" 
      block
      color="#FF6B9D"
      bind:click="requestSubscribeMessage"
    >
      订阅消息通知
    </van-button>
    <view class="subscribe-tip">
      <text>点击订阅后，你将收到微信服务通知</text>
    </view>
  </view>

  <!-- 时间选择器弹窗 -->
  <van-popup 
    show="{{ timePickerVisible }}" 
    position="bottom"
    bind:close="closeTimePicker"
  >
    <van-datetime-picker
      type="time"
      value="{{ currentTime }}"
      bind:confirm="onTimeConfirm"
      bind:cancel="closeTimePicker"
    />
  </van-popup>
</view>
